    "review::.::holistic::design_coherence::logsocket_multi_responsibility_store::99e4fa44": {
      "id": "review::.::holistic::design_coherence::logsocket_multi_responsibility_store::99e4fa44",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Log socket store module mixes unrelated responsibilities and hides failure paths.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "ui/src/lib/stores/logsocket.js",
          "ui/src/lib/runtime/transport/websocket-client.js",
          "ui/src/lib/runtime/transport/json.js"
        ],
        "evidence": [
          "`logsocket.js` owns session registry (`sessionsByType`), websocket event wiring, token loading (`loadSession()`), request serialization, parse handling, and UI state mutation (`logs.update`) in one file.",
          "`connect()` returns `{ ok: true }` immediately after `socketClient.connect()` regardless of actual open/error outcomes.",
          "`onOpen` calls async `requestLogs(logType)` without handling the returned error result, so bootstrapping failures are silent to callers."
        ],
        "suggestion": "Split the module into a transport/session service and a pure store reducer layer; make connect/request lifecycle explicit by returning a promise or evented status that includes initial subscription success/failure.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T08:35:44+00:00",
