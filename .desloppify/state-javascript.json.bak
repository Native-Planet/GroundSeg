      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Public command APIs mix async/sync and inconsistent send contracts",
      "detail": {
        "holistic": true,
        "dimension": "api_surface_coherence",
        "related_files": [
          "ui/src/lib/stores/websocket.js",
          "ui/src/lib/stores/logsocket.js",
          "ui/src/lib/stores/gs-crypto.js"
        ],
        "evidence": [
          "Some API methods are async without awaiting internal work (for example beginSetup/setupSkip variants), while many peers are sync wrappers.",
          "send in websocket.js accepts payload objects, while send in logsocket.js accepts logType and internally builds payload."
