    "review::.::holistic::mid_level_elegance::boundary_handoffs_are_manual_and_redundant::6c773490": {
      "id": "review::.::holistic::mid_level_elegance::boundary_handoffs_are_manual_and_redundant::6c773490",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Integration seams rely on duplicated payload assembly and ad-hoc transport glue",
      "detail": {
        "holistic": true,
        "dimension": "mid_level_elegance",
        "related_files": [
          "ui/src/lib/stores/websocket.js",
          "ui/src/lib/stores/logsocket.js",
          "ui/src/lib/stores/gs-crypto.js"
        ],
        "evidence": [
          "Token/session enrichment, command payload construction, and send semantics are manually repeated across modules.",
          "There is no single boundary adapter translating domain intent to transport wire format."
        ],
        "suggestion": "Create a seam layer with `buildCommand`, `attachSession`, and `sendTransport` primitives, then migrate websocket/logsocket callers incrementally to remove duplicated glue code.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
