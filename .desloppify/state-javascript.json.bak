    "review::.::holistic::api_surface_coherence::implicit_async_socket_contracts::8d1f55ed": {
      "id": "review::.::holistic::api_surface_coherence::implicit_async_socket_contracts::8d1f55ed",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Socket-facing APIs expose inconsistent async shapes and missing readiness/error contracts.",
      "detail": {
        "holistic": true,
        "dimension": "api_surface_coherence",
        "related_files": [
          "ui/src/lib/stores/logsocket.js",
          "goseg/web/_app/immutable/chunks/websocket.84e20bf3.js",
          "ui/src/lib/stores/websocket-commands.js"
        ],
        "evidence": [
          "`connect` and `requestLogs` in `logsocket.js` are declared `async` but do not define success/failure semantics for callers; errors are logged to console, not surfaced.",
          "`requestLogs` uses `SESSION[logType].send(...)` without verifying `SESSION[logType]` exists and is open, so caller-visible behavior depends on timing and hidden global state.",
          "Command-sending entrypoints in bundled websocket code (`e(...)`) are also fire-and-forget and do not return structured command acknowledgements, despite separate ack handling existing internally."
        ],
        "suggestion": "Define a uniform command/send contract that returns a promise resolving/rejecting on ack or transport failure, and enforce socket readiness checks before send; expose these guarantees consistently in both log socket and command socket APIs.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
