    "review::.::holistic::contract_coherence::restore_backup_ignores_argument::be603e79": {
      "id": "review::.::holistic::contract_coherence::restore_backup_ignores_argument::be603e79",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "restoreBackup ignores its backupFile argument and sends a hardcoded failing payload",
      "detail": {
        "holistic": true,
        "dimension": "contract_coherence",
        "related_files": [
          "ui/src/lib/stores/websocket.js",
          "ui/src/lib/stores/uploader.js"
        ],
        "evidence": [
          "restoreBackup(patp, backupFile) sets payload.file to literal \"this must fail\" instead of using backupFile.",
          "Uploader flow is intended to provide real file/chunk data, so this breaks the expected call contract."
        ],
        "suggestion": "Change restoreBackup to serialize and send the supplied backupFile (or remove the parameter if unsupported), and add an explicit error return when file input is invalid.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
