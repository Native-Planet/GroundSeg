    "review::.::holistic::abstraction_fitness::command_wrappers_lack_leverage::b58af5fc": {
      "id": "review::.::holistic::abstraction_fitness::command_wrappers_lack_leverage::b58af5fc",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "websocket.js command API is mostly repetitive pass-through wrappers",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "ui/src/lib/stores/websocket.js",
          "ui/src/lib/stores/logsocket.js",
          "ui/src/lib/stores/urbit.js"
        ],
        "evidence": [
          "Dozens of functions in websocket.js only build a literal payload and call send(payload).",
          "Sibling transport modules repeat similar connection and message boilerplate instead of sharing a reusable command/transport abstraction."
        ],
        "suggestion": "Replace per-command wrappers with declarative command specs (type/action + schema) and generate small typed builders per domain module; centralize transport plumbing in one shared client layer.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
