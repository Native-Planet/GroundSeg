    "review::.::holistic::design_coherence::command_wrapper_proliferation::d1363176": {
      "id": "review::.::holistic::design_coherence::command_wrapper_proliferation::d1363176",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Command modules repeat boilerplate wrapper patterns instead of using a coherent command schema.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "ui/src/lib/runtime/commands/ship-commands.js",
          "ui/src/lib/runtime/commands/system-commands.js",
          "ui/src/lib/runtime/commands/auth-commands.js",
          "ui/src/lib/runtime/commands/context.js"
        ],
        "evidence": [
          "Most exported command functions only forward constants plus lightly reshaped payloads into `sendActionCommand`/`sendTypeCommand`.",
          "Parameter naming and payload shaping is inconsistent across wrappers (`pwd`, `val`, `old`) and each function hand-encodes type/action strings.",
          "Validation policy is uneven: `bootShip` uses `sendValidatedCommand`, while other wrappers with required intent fields bypass it entirely."
        ],
        "suggestion": "Replace per-function boilerplate with a shared command descriptor table (type/action/required fields/payload mapper), then generate handlers from descriptors so naming, validation, and transport behavior are centralized and consistent.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T08:35:44+00:00",
