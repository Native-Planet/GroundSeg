    "review::.::holistic::cross_module_architecture::import_time_singleton_side_effects::bc425b63": {
      "id": "review::.::holistic::cross_module_architecture::import_time_singleton_side_effects::bc425b63",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Module evaluation in the Urbit realtime chunk performs hidden lifecycle setup through singleton construction and global event listener registration.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/web/_app/immutable/chunks/urbit.f551ce98.js",
          "goseg/web/_app/immutable/chunks/websocket.84e20bf3.js"
        ],
        "evidence": [
          "`urbit.f551ce98.js` constructs `const f=new v(\"\")` at module scope, so stateful runtime object creation happens on import.",
          "Class `v` constructor conditionally registers `window.addEventListener(\"beforeunload\", this.delete)`, coupling module import order to browser lifecycle behavior.",
          "The same file mutates singleton callbacks (`f.onOpen=...`, `f.onRetry=...`, `f.onError=...`) later via exported functions, creating implicit global state transitions across consumers."
        ],
        "suggestion": "Remove module-scope singleton instantiation and replace with an explicit factory/init phase managed by an orchestrator module; register/unregister browser lifecycle hooks during connect/disconnect, not at import time.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
