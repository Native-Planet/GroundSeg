    "review::.::holistic::error_consistency::socket_json_parse_unprotected::5eda965d": {
      "id": "review::.::holistic::error_consistency::socket_json_parse_unprotected::5eda965d",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Socket message parsing is unguarded in websocket/logsocket while urbit path handles parse errors",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "ui/src/lib/stores/websocket.js",
          "ui/src/lib/stores/logsocket.js",
          "ui/src/lib/stores/urbit.js"
        ],
        "evidence": [
          "websocket.js and logsocket.js call JSON.parse(message.data) directly in onmessage handlers.",
          "urbit.js wraps JSON.parse(event.cord) in try/catch and aborts gracefully on parse failures."
        ],
        "suggestion": "Introduce a shared safe-parse helper for all transport handlers and standardize failure behavior (structured error store update + optional reconnect strategy) across websocket/logsocket/urbit.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
