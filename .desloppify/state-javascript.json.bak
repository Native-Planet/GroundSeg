      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Store updates mutate existing objects in place, hiding side-effect boundaries",
      "detail": {
        "holistic": true,
        "dimension": "low_level_elegance",
        "related_files": [
          "ui/src/lib/stores/websocket.js",
          "ui/src/lib/stores/logsocket.js"
