    "review::.::holistic::cross_module_architecture::websocket_chunk_hub_module::209091e1": {
      "id": "review::.::holistic::cross_module_architecture::websocket_chunk_hub_module::209091e1",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "A single websocket chunk acts as a cross-cutting god module, coupling transport, auth persistence, state dispatch, and dozens of domain commands.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/web/_app/immutable/chunks/websocket.84e20bf3.js",
          "goseg/web/_app/immutable/entry/apps-page.svelte.85e3c543.js",
          "goseg/web/_app/immutable/entry/boot-existing-page.svelte.509e2e47.js",
          "goseg/web/_app/immutable/entry/captive-page.svelte.525c6d92.js",
          "goseg/web/_app/immutable/entry/system-page.svelte.d284871e.js"
        ],
        "evidence": [
          "`chunks/websocket.84e20bf3.js` contains transport setup (`p=new WebSocket(t)`), retry logic (`setTimeout(()=>M(t),1e3)`), token persistence (`localStorage.setItem`), event routing (`D=t=>...`), and a long list of command wrappers (`j`, `q`, `V`, `Y`, `K`, `ot`, `lt`, `kt`, etc.) in one file.",
          "Entry bundles import this module directly, making page-level behavior depend on a broad shared hub rather than narrower capability interfaces.",
          "Because commands and socket lifecycle are co-located, changing one domain action shape forces edits in the same high-fanout module that handles unrelated domains."
        ],
        "suggestion": "Split the websocket chunk responsibilities behind stable boundaries: isolate transport/session lifecycle, isolate auth token persistence, and expose domain command adapters from per-domain modules. Keep page entries importing only the minimal adapter they need.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T08:35:44+00:00",
      "last_seen": "2026-03-01T08:35:44+00:00",
      "resolved_at": "2026-03-01T08:39:07+00:00",
