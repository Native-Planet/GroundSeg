    "review::.::holistic::package_organization::generated_tree_overexposed_in_main_layout::67c4ee5c": {
      "id": "review::.::holistic::package_organization::generated_tree_overexposed_in_main_layout::67c4ee5c",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Generated immutable artifacts are organized as primary package structure instead of a bounded distribution package.",
      "detail": {
        "holistic": true,
        "dimension": "package_organization",
        "related_files": [
          "README.md",
          "goseg/web/_app/immutable/entry/captive-page.svelte.525c6d92.js",
          "goseg/web/_app/immutable/chunks/urbit.f551ce98.js"
        ],
        "evidence": [
          "Structure profile shows large generated directories (`entry/` 31 files, `chunks/` 49 files), indicating flat artifact-heavy layout beyond cohesive package boundaries.",
          "Reviewed files mix feature semantics (apps/captive/boot) with bundler-oriented placement (`entry` vs `chunks`), which is optimized for runtime loading, not repository ownership.",
          "README warns against hand-editing these files, confirming they are distribution outputs, yet they remain exposed under a path that behaves like ordinary package structure."
        ],
        "suggestion": "Staged reorg plan: (1) create `goseg/web/generated/<build-id>/` as the sole committed distribution package with `manifest.json`; (2) move `entry/*` first, then `chunks/*`, preserving relative references via manifest-driven path rewrite; (3) update serving/config references to the new generated root; (4) run `cd ui && npm ci && npm run build` then validate with `rg -n \"_app/immutable|generated/<build-id>\" README.md goseg` and a startup smoke test to confirm imports resolve.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
