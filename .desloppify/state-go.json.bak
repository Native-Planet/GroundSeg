    "review::.::holistic::design_coherence::broadcast_god_module::ea5b179f": {
      "id": "review::.::holistic::design_coherence::broadcast_god_module::ea5b179f",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Broadcast package combines snapshot building, domain aggregation, transport emission, and global state mutation in one module.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/broadcast/broadcast.go",
          "goseg/system/system.go",
          "goseg/config/config.go",
          "goseg/docker/docker.go"
        ],
        "evidence": [
          "`broadcast.go` constructs urbit/profile/apps/system views, mutates module globals, queries docker/system/config, and emits websocket updates in the same package.",
          "`runtimeSnapshotForPiers` mutates `docker.ContainerStatList` as a side effect while assembling broadcast snapshots.",
          "`constructSystemInfo` and `assembleUrbitView` are long aggregation functions with cross-domain reads and formatting rules embedded directly."
        ],
        "suggestion": "Split broadcast into focused collaborators: snapshot collectors (system/docker/startram), pure view mappers, and a thin publisher; remove side-effectful cross-package mutation from snapshot assembly paths.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T14:15:26+00:00",
      "last_seen": "2026-03-01T14:15:26+00:00",
      "resolved_at": "2026-03-01T15:34:20+00:00",
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
