    "review::.::holistic::design_coherence::config_package_mixed_runtime_and_persistence_concerns::a12e410d": {
      "id": "review::.::holistic::design_coherence::config_package_mixed_runtime_and_persistence_concerns::a12e410d",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Configuration modules mix unrelated responsibilities (bootstrap, runtime caches, persistence, and external system probing).",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/config/config.go",
          "goseg/config/urbit.go",
          "goseg/config/version.go"
        ],
        "evidence": [
          "`config/config.go` `init()` performs environment bootstrap, file/key creation, defaults merge, binary hashing, persistence, and starts background channel processing in one package entrypoint.",
          "The same file owns both typed patch API (`ConfPatch`/`With*` options) and legacy raw map mutation (`UpdateConf`), creating two mutation paths to one store.",
          "`config/urbit.go` persistence path (`persistUrbitConfigLocked`) also performs Docker container inspection (`getImageTagByContainerName`) before writing config, crossing config/storage and runtime-infra boundaries."
        ],
        "suggestion": "Split config responsibilities into separate components: bootstrapping, repository/persistence, runtime snapshot access, and runtime enrichers (e.g., image tag resolvers). Keep one mutation pathway and make runtime-derived fields explicit outside persistence writes.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T15:37:31+00:00",
