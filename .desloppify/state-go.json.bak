      "tier": 3,
      "confidence": "high",
      "summary": "A global `SysConfig` bag leaks through multiple layers, so callers depend on broad mutable state instead of bounded configuration contracts.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
