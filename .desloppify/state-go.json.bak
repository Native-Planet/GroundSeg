    "review::.::holistic::error_consistency::unhandled_system_shutdown_command_errors::84de7502": {
      "id": "review::.::holistic::error_consistency::unhandled_system_shutdown_command_errors::84de7502",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "System power/restart command failures are dropped, so callers can receive success while critical host operations did not execute.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "goseg/handler/systemsvc/system.go",
          "goseg/handler/system/system.go"
        ],
        "evidence": [
          "`goseg/handler/systemsvc/system.go` creates command runners and calls `cmd.Run()` without checking returned error for restart/shutdown branches (`...groundseg` and `shutdown` cases).",
          "Same pathway publishes transition events before and during command execution in `handler/systemsvc/system.go`, so externally visible state can be misleading."
        ],
        "suggestion": "Capture and return `Run()` errors from command execution, and only publish terminal-success transition states once command invocation is confirmed; map failures to explicit error transitions.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T17:37:55+00:00",
