      "id": "review::.::holistic::design_coherence::orchestration_ui_state_coupling::bf63be49",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Ship/startram/import workflows duplicate UI-transition choreography inside domain operations, creating a repeated mixed-responsibility pattern.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
