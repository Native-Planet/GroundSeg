    "review::.::holistic::design_coherence::handler_layer_contains_domain_and_infra_workflows::f3d0d9f4": {
      "id": "review::.::holistic::design_coherence::handler_layer_contains_domain_and_infra_workflows::f3d0d9f4",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Handler layer performs deep domain workflows and infrastructure mutations instead of delegating to cohesive application services.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/handler/newship.go",
          "goseg/handler/handler.go",
          "goseg/handler/startram.go",
          "goseg/handler/urbit_operations.go"
        ],
        "evidence": [
          "`NewShipHandler` validates protocol payloads, derives keys, resolves drives, and dispatches destructive operations; `createUrbitShip` then manipulates Docker volumes/containers, config state, and StarTram registration.",
          "`StartramHandler` switch branches build inline closures and trigger asynchronous orchestration functions that themselves perform cross-module config/docker/startram operations.",
          "`urbit_operations.go` centralizes many unrelated actions (domain aliasing, export, power/network toggles, backups, chop scheduling), creating a broad command surface in one file."
        ],
        "suggestion": "Refactor handlers into thin transport adapters that map request -> command object, with command execution moved into focused application services (ship provisioning, startram orchestration, urbit operations), each with bounded dependencies.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T15:37:31+00:00",
