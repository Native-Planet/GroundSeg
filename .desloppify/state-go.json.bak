    "review::.::holistic::design_coherence::dup_urbit_wait_persist_flow::3d42e839": {
      "id": "review::.::holistic::design_coherence::dup_urbit_wait_persist_flow::3d42e839",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Urbit lifecycle helpers are duplicated across packages instead of being owned by one domain service.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/chopsvc/service.go",
          "goseg/handler/urbit.go"
        ],
        "evidence": [
          "`WaitComplete` in both files has near-identical timeout/poll/retry/status-check flow against `docker.GetShipStatus` with the same failure-counter behavior.",
          "Both files define a `persistShipConf` helper with the same `config.UpdateUrbit` mutation closure (`*conf = shipConf`).",
          "The duplicated helpers are used in operational paths (`ChopPier`/delete flows), so behavior changes can drift between copies."
        ],
        "suggestion": "Move wait/persist lifecycle primitives into a single shared Urbit lifecycle component (for example under `chopsvc` or a dedicated `shipworkflow` service) and have handlers call that component instead of carrying their own copies.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T15:37:31+00:00",
