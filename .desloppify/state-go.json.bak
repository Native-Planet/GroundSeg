    "review::.::holistic::design_coherence::god_handler_and_orchestration_mix::239b8c02": {
      "id": "review::.::holistic::design_coherence::god_handler_and_orchestration_mix::239b8c02",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Core handler/orchestration files mix unrelated responsibilities, reducing clarity and increasing regression risk.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/handler/urbit.go",
          "goseg/main.go",
          "goseg/handler/handler.go",
          "goseg/startram/startram.go"
        ],
        "evidence": [
          "goseg/handler/urbit.go is 1233 lines and combines websocket action dispatch, domain validation, docker lifecycle operations, scheduling, backups, and transition signaling.",
          "goseg/main.go combines connectivity mode switching, update coordination, service loading, goroutine orchestration, and HTTP server startup in one flow (notably lines 245-336).",
          "goseg/handler/handler.go NewShipHandler also embeds validation, filesystem provisioning, and cross-handler invocation."
        ],
        "suggestion": "Split by bounded responsibilities: separate command parsing, domain services (ship lifecycle, scheduling, backup), and infrastructure adapters; keep handlers thin and make orchestration explicit through service interfaces.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
