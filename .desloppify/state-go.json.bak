    "review::.::holistic::design_coherence::state_ownership_and_mutability_blur::4dce5e5e": {
      "id": "review::.::holistic::design_coherence::state_ownership_and_mutability_blur::4dce5e5e",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Shared mutable state ownership is unclear across config/auth/broadcast",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/config/config.go",
          "goseg/auth/auth.go",
          "goseg/structs/ws.go",
          "goseg/broadcast/broadcast.go"
        ],
        "evidence": [
          "`GetContainerState()` returns the internal `GSContainers` map directly after unlocking (`goseg/config/config.go` 362-366), allowing external mutation without synchronization.",
          "`auth` and `structs.ClientManager` both manipulate client/session maps through mixed direct map iteration and helper methods, while broadcast reads/writes these structures concurrently (`auth.go` 88-155, `ws.go` 115-240, `broadcast.go` 583-603).",
          "`broadcastState` and transition maps are global package state with multiple ad-hoc mutexes (`goseg/broadcast/broadcast.go` 25-37), increasing the chance of inconsistent update conventions."
        ],
        "suggestion": "Define clear ownership boundaries for shared state: expose read-only snapshots/copies from config state getters, centralize session-map mutation behind one API in `ClientManager`, and encapsulate broadcast state in a single state store struct with consistent locking semantics.",
        "reasoning": ""
      },
      "status": "auto_resolved",
