      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Remote readiness loop can return before readiness and both readiness loops can wait forever without cancellation.",
      "detail": {
        "holistic": true,
        "dimension": "logic_clarity",
        "related_files": [
          "goseg/handler/newship.go",
          "goseg/handler/urbit.go"
