    "review::.::holistic::abstraction_fitness::wide_global_config_bag_dependency::a4311a51": {
      "id": "review::.::holistic::abstraction_fitness::wide_global_config_bag_dependency::a4311a51",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Modules depend on full mutable `SysConfig` instead of narrow settings contracts.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "goseg/config/config.go",
          "goseg/main.go",
          "goseg/handler/startram.go",
          "goseg/importer/importer.go",
          "goseg/docker/urbit.go"
        ],
        "evidence": [
          "`config.Conf()` returns full `structs.SysConfig` (`goseg/config/config.go`), and call sites across modules pull only subsets (for example `WgRegistered`, `WgOn`, `Piers`, `SnapTime`).",
          "`goseg/main.go`, `goseg/handler/startram.go`, and `goseg/importer/importer.go` each read broad config state for orchestration decisions, coupling unrelated logic to a monolithic bag.",
          "`goseg/config/config.go` already defines narrower snapshots (`StartramSettingsSnapshot`, `ShipSettingsSnapshot`, `RuntimeSettingsSnapshot`) but core callers still use `Conf()` directly."
        ],
        "suggestion": "Adopt narrow read models at boundaries: replace direct `Conf()` calls in orchestration paths with dedicated snapshot/accessor APIs per concern (startram, ships, runtime). Phase out `Conf()` usage in non-config packages except where full state is genuinely required.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T13:23:44+00:00",
