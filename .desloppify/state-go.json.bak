    "review::.::holistic::cross_module_architecture::transport_dto_leaks_into_service_boundary::6804637c": {
      "id": "review::.::holistic::cross_module_architecture::transport_dto_leaks_into_service_boundary::6804637c",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Upload service layer is directly coupled to websocket payload structs.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/uploadsvc/service.go",
          "goseg/handler/upload.go"
        ],
        "evidence": [
          "`uploadsvc.OpenEndpointRequestFromWsPayload` accepts `structs.WsUploadPayload`, forcing service code to import transport-layer types.",
          "Handler routing in `UploadMessageHandler.Handle` switches transport action strings and then delegates transport-to-domain conversion to `uploadsvc`, so boundary translation responsibility is not isolated at the edge."
        ],
        "suggestion": "Move `OpenEndpointRequestFromWsPayload` out of `uploadsvc` into `handler` (or a dedicated transport adapter package). Keep `uploadsvc` accepting only `OpenEndpointRequest` and domain-level types so websocket schema changes do not force service-package edits.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
