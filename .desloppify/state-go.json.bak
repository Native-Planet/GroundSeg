    "review::.::holistic::design_coherence::transition_choreography_scattered::0fbae58f": {
      "id": "review::.::holistic::design_coherence::transition_choreography_scattered::0fbae58f",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Transition/event lifecycle management is hand-coded in many handlers with repeated sleep/clear/error patterns.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/handler/newship.go",
          "goseg/handler/support.go",
          "goseg/handler/startram.go",
          "goseg/handler/urbit_operations.go",
          "goseg/importer/importer.go"
        ],
        "evidence": [
          "`newship`, `support`, `startram`, and `urbit_operations` each define local error wrappers that publish transition errors, sleep, and clear transitions.",
          "`importer/Reset` and `failUploadRequest` manually emit multiple status transitions in fixed sequences, duplicating lifecycle semantics present in other flows.",
          "Transition keys and completion behavior are encoded as string literals in each handler, creating inconsistent conventions and repeated orchestration logic."
        ],
        "suggestion": "Introduce a shared transition orchestrator API (begin/progress/fail/complete/clear with optional auto-clear timing) and migrate handlers to declarative transition steps rather than inline publish-and-sleep blocks.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
