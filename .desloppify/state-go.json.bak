    "review::.::holistic::design_coherence::wifi_module_mixed_transport_and_system_control::b82134af": {
      "id": "review::.::holistic::design_coherence::wifi_module_mixed_transport_and_system_control::b82134af",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "WiFi module mixes device control, AP lifecycle, websocket API handling, and shared mutable state without a clear boundary.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/system/wifi.go",
          "goseg/handler/handler.go",
          "goseg/accesspoint/accesspoint_test.go"
        ],
        "evidence": [
          "`wifi.go` holds websocket upgrader/client map, captive portal config, wifi polling loop, and nmcli/systemctl command execution in one package-level module.",
          "Global mutable structures (`clients`, `WifiInfo`, `Device`, `ConfChannel`) are read/written across goroutines with partial locking only for C2C mode flag.",
          "Handler layer delegates directly to this broad module (`C2CHandler`), reinforcing a coarse interface instead of a focused service boundary."
        ],
        "suggestion": "Split wifi responsibilities into separate components (radio control service, AP/captive service, websocket adapter) with explicit synchronization and narrow interfaces; keep handler-facing API at a use-case level.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T14:15:26+00:00",
      "last_seen": "2026-03-01T14:15:26+00:00",
