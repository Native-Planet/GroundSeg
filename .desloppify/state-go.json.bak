    "review::.::holistic::design_coherence::lifecycle_dockerpoller_single_tick_exit::f395e768": {
      "id": "review::.::holistic::design_coherence::lifecycle_dockerpoller_single_tick_exit::f395e768",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Docker polling loop returns after first tick, so recurring lifecycle work never runs.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/docker/lifecycle/lifecycle.go",
          "goseg/docker/orchestration/netdata.go"
        ],
        "evidence": [
          "`DockerPoller` uses `for { select { case <-ticker.C: ... return } }` which exits on the first tick.",
          "Name and implementation imply a long-lived poller, but current control flow makes it effectively one-shot."
        ],
        "suggestion": "Replace `return` with periodic dispatch (or remove `select` entirely and run the poll handler directly in the loop) so the function continuously polls and calls container orchestration reconciliation work.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T18:19:05+00:00",
