    "review::.::holistic::test_strategy::hardwired_io_prevents_reliable_tests::b783f7dd": {
      "id": "review::.::holistic::test_strategy::hardwired_io_prevents_reliable_tests::b783f7dd",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Hardcoded HTTP/time/filesystem dependencies in critical functions make deterministic contract tests difficult and encourage under-testing.",
      "detail": {
        "holistic": true,
        "dimension": "test_strategy",
        "related_files": [
          "goseg/config/version.go",
          "goseg/handler/upload.go",
          "goseg/startram/startram.go"
        ],
        "evidence": [
          "CheckVersion directly uses http.DefaultClient.Do, retry sleeps, and direct file writes to settings/version_info.json in one flow.",
          "Startram functions use direct http.Get/http.Post and internal retry/backoff loops (backoffRetrieve) without injected clock/client.",
          "UploadHandler directly invokes importer.SetUploadSession/importer.Reset based on action strings, with no local seam for controlled behavioral tests."
        ],
        "suggestion": "Refactor these modules to accept injected HTTP client, clock/sleeper, and persistence/action interfaces, then add table-driven tests for success/failure/timeout branches and action validation.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T09:04:04+00:00",
