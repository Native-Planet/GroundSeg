    "review::.::holistic::error_consistency::ignored_filesystem_restructure_errors::a1779fa7": {
      "id": "review::.::holistic::error_consistency::ignored_filesystem_restructure_errors::a1779fa7",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Importer directory restructuring suppresses filesystem and walk errors, allowing silent partial migrations that can break restore/import determinism.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "goseg/importer/importer.go",
          "goseg/importer/extract.go"
