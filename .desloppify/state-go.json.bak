    "review::.::holistic::error_consistency::handler_error_surface_varies_between_returned_and_side_channel_failures::b663279e": {
      "id": "review::.::holistic::error_consistency::handler_error_surface_varies_between_returned_and_side_channel_failures::b663279e",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Adjacent handler pathways expose failures through incompatible channels (returned error vs log/event side effects), making caller behavior unpredictable.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "goseg/handler/upload.go",
          "goseg/system/wifi.go",
          "goseg/handler/startram.go"
        ],
        "evidence": [
          "`goseg/handler/upload.go` consistently returns wrapped errors to caller (`open upload endpoint ...: %w`), enabling deterministic propagation.",
          "`goseg/system/wifi.go` captive websocket loop mostly logs and continues on decode/connect/write failures, with no propagated error to HTTP layer.",
          "`goseg/handler/startram.go` helper actions frequently log and return from void functions, reporting status via events only, not a shared error-return contract."
        ],
        "suggestion": "Standardize handler-facing error semantics: either return typed errors from action handlers and translate once at transport boundary, or formalize an explicit result/event contract used consistently across handlers.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T14:02:02+00:00",
