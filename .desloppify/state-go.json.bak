      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Failure handling mixes panic/exit/silent continuation across adjacent startup and handler paths.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "goseg/config/config.go",
          "goseg/broadcast/broadcast.go",
