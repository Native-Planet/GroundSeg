      "id": "review::.::holistic::cross_module_architecture::upload_handler_global_mutable_dependency::cf5a46a0",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Upload handler relies on mutable global service state, creating order-dependent behavior across modules.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/handler/upload.go",
          "goseg/startram/errors.go"
        ],
        "evidence": [
          "upload.go declares `var defaultUploadService UploadService = importerUploadService{}` and allows runtime replacement via `SetUploadService`.",
          "Handler execution (`UploadHandler`) reads this global directly, so behavior depends on who last mutated shared package state.",
          "Compared with startram/errors.go's pure function-style wrapper (`wrapAPIConnectionError(err)`), this mutable approach introduces broader cross-module side-effect risk."
        ],
        "suggestion": "Replace `SetUploadService`/global state with explicit dependency injection (e.g., a handler struct receiving `UploadService`), and pass that dependency from composition root to eliminate shared mutable coordination.",
        "reasoning": ""
      },
