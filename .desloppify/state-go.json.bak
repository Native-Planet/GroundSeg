    "review::.::holistic::error_consistency::error_wrapping_contract_is_inconsistent::fdf7ea3b": {
      "id": "review::.::holistic::error_consistency::error_wrapping_contract_is_inconsistent::fdf7ea3b",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Mixed `%w` and `%v` wrapping across packages causes uneven context preservation and prevents reliable `errors.Is/As` handling.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "goseg/system/system.go",
          "goseg/routines/docker.go",
          "goseg/handler/dev.go",
          "goseg/handler/handler.go"
        ],
        "evidence": [
          "`goseg/system/system.go` preserves causal chains with `%w` (for example `read virtual memory stats: %w`), but `goseg/routines/docker.go` uses `%v` for similar boundary errors (for example `Failed to get statuses for %s: %v`).",
          "`goseg/handler/handler.go` uses wrapped errors in many handlers, while `goseg/handler/dev.go` often formats with `%v`, creating inconsistent upstream behavior for classification/retry logic."
        ],
        "suggestion": "Adopt a package-wide rule: wrap propagated errors with `%w`, reserve `%v` for terminal logging only, and migrate high-traffic boundary functions first (handlers, routines, system).",
        "reasoning": ""
      },
      "status": "auto_resolved",
