    "review::.::holistic::design_coherence::inconsistent_transition_orchestration_pattern::45ce86f0": {
      "id": "review::.::holistic::design_coherence::inconsistent_transition_orchestration_pattern::45ce86f0",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Transition/event lifecycle handling is scattered and inconsistently encoded across handlers.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/handler/support.go",
          "goseg/handler/startram.go",
          "goseg/handler/newship.go",
          "goseg/handler/urbit_operations.go"
        ],
        "evidence": [
          "`SupportHandler` manually emits loading/error/reset transitions with hardcoded deferred sleeps and reset events.",
          "`handleStartramRestart`/`handleStartramToggle` partially use `publishTransitionWithPolicy`, but still embed event-type-specific reset payload forms (`nil`, empty string, or explicit data) inline.",
          "`newship.go` publishes transitions directly (`bootStage`, `error`, `patp`) without a common lifecycle wrapper, unlike other handler flows."
        ],
        "suggestion": "Introduce a single transition orchestration abstraction (state machine or typed helper) for start/success/error/reset semantics, and migrate handler actions to declarative transition steps rather than ad-hoc publish/sleep blocks.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T15:37:31+00:00",
