    "review::.::holistic::cross_module_architecture::global_state_cross_boundary_coupling::e51a570b": {
      "id": "review::.::holistic::cross_module_architecture::global_state_cross_boundary_coupling::e51a570b",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Cross-module coordination relies on mutable package globals, creating hidden coupling and broad change blast radius.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/startram/startram.go",
          "goseg/config/version.go"
        ],
        "evidence": [
          "goseg/startram/startram.go:33-36 defines mutable globals (`EventBus`, `Regions`), and `GetRegions` overwrites `Regions` at line 64.",
          "goseg/startram/startram.go:98 writes into external package global `config.StartramConfig` during `Retrieve`.",
          "goseg/config/version.go:17-20 defines mutable globals (`VersionServerReady`, `VersionInfo`) and `CheckVersion` mutates/returns them as implicit shared state (lines 46-47, 77, 94-95)."
        ],
        "suggestion": "Introduce explicit state owners with interfaces (e.g., `StartramStore`, `VersionStore`) and inject them into call sites; replace package-global mutable variables with encapsulated structs guarded by synchronization where needed.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T09:04:04+00:00",
      "last_seen": "2026-03-01T09:04:04+00:00",
      "resolved_at": "2026-03-01T09:10:05+00:00",
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::cross_module_architecture::transport_domain_persistence_mixed_in_single_modules::e1ccd047": {
      "id": "review::.::holistic::cross_module_architecture::transport_domain_persistence_mixed_in_single_modules::e1ccd047",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Network transport logic is tightly mixed with config persistence and event emission, collapsing module boundaries.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/startram/startram.go",
          "goseg/config/version.go",
          "goseg/handler/upload.go"
        ],
        "evidence": [
          "goseg/startram/startram.go `Retrieve` performs HTTP, decodes payload, mutates config state (`config.UpdateConf` at lines 107-109), and emits module event (`EventBus <- ...` at line 117) in one flow.",
          "goseg/config/version.go `CheckVersion` performs HTTP polling and also writes a persisted JSON snapshot to disk (`os.Create` line 80, encoder writes lines 88-90).",
          "goseg/handler/upload.go delegates directly to importer session mutation (`importer.SetUploadSession`, `importer.Reset`) from websocket action dispatch, without an intermediate application service boundary."
        ],
        "suggestion": "Split responsibilities into explicit layers: API client layer for HTTP calls, domain service layer for registration/version workflows, and persistence/event adapters; handlers should call service interfaces, not storage/session primitives directly.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T09:04:04+00:00",
      "last_seen": "2026-03-01T09:04:04+00:00",
      "resolved_at": "2026-03-01T09:10:05+00:00",
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::cross_module_architecture::bidirectional_config_startram_dependency_drift::9fe55f92": {
      "id": "review::.::holistic::cross_module_architecture::bidirectional_config_startram_dependency_drift::9fe55f92",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Startram and config modules are mutually entangled through reads and writes, weakening dependency direction.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/startram/startram.go",
          "goseg/config/version.go"
        ],
        "evidence": [
          "goseg/startram/startram.go depends on config for runtime reads (`config.Conf()` throughout) and writes (`config.UpdateConf`, `config.StartramConfig` mutation).",
          "goseg/config/version.go maintains its own remote-fetch orchestration and global status state rather than depending on a dedicated outbound service abstraction, reinforcing horizontal coupling between runtime config and external API concerns."
        ],
        "suggestion": "Define a narrow configuration interface consumed by startram (read/update methods only) and move external API orchestration into dedicated service packages so config remains a state provider instead of a peer orchestrator.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T09:04:04+00:00",
      "last_seen": "2026-03-01T09:04:04+00:00",
      "resolved_at": "2026-03-01T09:10:05+00:00",
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::cross_module_architecture::startram_boundary_collapse::abcc5a73": {
      "id": "review::.::holistic::cross_module_architecture::startram_boundary_collapse::abcc5a73",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Startram service operations collapse transport, state mutation, and event publication into single entrypoints, creating hidden cross-module contracts.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/startram/startram.go",
          "README.md"
        ],
        "evidence": [
          "Retrieve updates config.StartramConfig, conditionally writes wgRegistered via config.UpdateConf, and emits EventBus events after remote API reads.",
          "Register/SvcDelete/AliasCreate call remote APIs and then trigger Retrieve-driven state synchronization, coupling endpoint behavior to local config/event semantics.",
          "README.md documents frontend ownership/contracts but no backend module-boundary contract for Startram side effects."
        ],
        "suggestion": "Introduce a Startram boundary layer that separates API client, state reconciliation, and event emission into distinct interfaces; document the backend boundary contract in README so callers depend on explicit outputs rather than side effects.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T09:04:04+00:00",
      "last_seen": "2026-03-01T09:04:04+00:00",
      "resolved_at": "2026-03-01T09:10:05+00:00",
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::cross_module_architecture::shared_mutable_runtime_state::376d29f7": {
      "id": "review::.::holistic::cross_module_architecture::shared_mutable_runtime_state::376d29f7",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Package-level mutable state in configuration/version and Startram modules creates non-local coupling and broad blast radius for behavior changes.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/config/version.go",
          "goseg/startram/startram.go"
        ],
        "evidence": [
          "goseg/config/version.go exposes and mutates VersionInfo and VersionServerReady globally in CheckVersion.",
          "goseg/startram/startram.go exposes EventBus and Regions as globals and mutates them inside request paths.",
          "These globals are updated during I/O-heavy flows, making behavior depend on call ordering across modules rather than explicit contracts."
        ],
        "suggestion": "Encapsulate mutable runtime state behind owned structs with constructor-injected dependencies; return immutable result objects to callers and publish events through an interface-owned dispatcher.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T09:04:04+00:00",
      "last_seen": "2026-03-01T09:04:04+00:00",
      "resolved_at": "2026-03-01T09:10:05+00:00",
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
