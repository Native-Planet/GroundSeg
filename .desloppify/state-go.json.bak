    "review::.::holistic::design_coherence::auth_module_overloaded_roles::8819ca4e": {
      "id": "review::.::holistic::design_coherence::auth_module_overloaded_roles::8819ca4e",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Auth package combines token cryptography, HTTP identity checks, websocket client registry, and session persistence in one module.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/auth/auth.go",
          "goseg/structs/ws.go",
          "goseg/handler/handler.go"
        ],
        "evidence": [
          "`auth/auth.go` includes token generation/encryption (`CreateToken`, `KeyfileEncrypt/Decrypt`, `AuthToken`) while also managing live connection maps (`AddToAuthMap`, `RemoveFromAuthMap`, `Ws*` helpers).",
          "`ValidateAndAuthorizeRequestToken` mixes HTTP request fingerprinting (`X-Forwarded-For`, `User-Agent`) with token mutation and authorization checks.",
          "Login flow in `handler/handler.go` directly depends on this all-in-one module for both auth decision and websocket/session side effects, tightening coupling."
        ],
        "suggestion": "Separate auth into at least three collaborators: token service (crypto + claims), request authenticator (context validation), and session/connection registry (websocket state + persistence). Keep handlers orchestrating these explicit interfaces instead of one omnibus package.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T15:37:31+00:00",
      "last_seen": "2026-03-01T15:37:31+00:00",
