    "review::.::holistic::abstraction_fitness::global_sysconfig_god_object_leakage::e8359362": {
      "id": "review::.::holistic::abstraction_fitness::global_sysconfig_god_object_leakage::e8359362",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Wide access to full `SysConfig` creates a leaky, low-cohesion dependency surface across unrelated modules.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "goseg/config/config.go",
          "goseg/broadcast/broadcast.go",
          "goseg/auth/auth.go",
          "goseg/handler/urbit_operations.go",
          "goseg/routines/version.go",
          "goseg/importer/importer.go"
        ],
        "evidence": [
          "`config.Conf()` returns full `structs.SysConfig`, and many modules call it directly for small subsets (sessions in `auth`, profile/app/system fields in `broadcast`, update settings in `routines/version`, endpoint/piers in handlers).",
          "Even where snapshot helpers exist (`StartramSettingsSnapshot`, `SwapSettingsSnapshot`, etc.), modules still frequently consume broad config state directly.",
          "This makes module boundaries implicit and brittle: changing `SysConfig` shape or initialization behavior can ripple across multiple subsystems."
        ],
        "suggestion": "Move callers to narrower typed snapshots/capabilities (e.g., auth settings, startram settings, update settings) and reserve full `Conf()` access for config package internals. Introduce focused read APIs per domain and phase out direct `SysConfig` reads in handlers/routines.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
