      "id": "review::.::holistic::design_coherence::duplicated_drive_provisioning_flow::185b8d5f",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Drive selection and GroundSeg mountpoint resolution are duplicated across new-ship and import flows instead of centralized.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/handler/handler.go",
          "goseg/handler/newship.go",
          "goseg/importer/importer.go",
          "goseg/system/disk.go"
        ],
        "evidence": [
          "`handler/NewShipHandler` scans block devices and decides whether to call `system.CreateGroundSegFilesystem` before ship creation.",
          "`handler/createUrbitShip` re-scans block devices and re-runs the same mountpoint regex check to compute `customDrive`.",
          "`importer/OpenUploadEndpoint` repeats the same `ListHardDisks` + `^/groundseg-\\d+$` mountpoint detection logic and separate formatting flag behavior."
        ],
        "suggestion": "Extract a single drive-provisioning service (for select/validate/format/mountpoint resolution) and call it from both new-ship and import paths; return a typed result (`mountpoint`, `formatted`, `needs_format`) to remove repeated branching.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
