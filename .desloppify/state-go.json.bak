      "tier": 3,
      "confidence": "high",
      "summary": "Importer workflow failures can be dropped because async execution ignores returned errors from upload processing.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "goseg/importer/importer.go",
          "goseg/importer/extract.go"
