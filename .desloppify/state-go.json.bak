    "review::.::holistic::abstraction_fitness::global_test_seams_in_runtime_code::859db81c": {
      "id": "review::.::holistic::abstraction_fitness::global_test_seams_in_runtime_code::859db81c",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Test seam strategy relies on runtime-global function variables, creating pervasive low-value indirection.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "goseg/docker/wireguard.go",
          "goseg/docker/minio.go",
          "goseg/docker/netdata.go",
          "goseg/docker/urbit.go",
          "goseg/routines/docker.go",
          "goseg/routines/version.go"
        ],
        "evidence": [
          "`goseg/docker/wireguard.go` declares many aliases like `startContainerForWireguard = StartContainer`, `getLatestContainerInfoForWireguard = GetLatestContainerInfo`, `confForWireguard = config.Conf`.",
          "`goseg/docker/minio.go` and `goseg/routines/docker.go` follow the same pattern (`confForMinIO`, `startContainerForMinIO`, `getContainerStateFn`, `updateWgOnFn`, etc.), and tests mutate those globals.",
          "This pattern makes call paths harder to follow in production and introduces shared mutable seams that couple runtime code structure to test setup."
        ],
        "suggestion": "Replace package-global seam variables with explicit dependency structs/interfaces constructed once per module (for example a `DockerRuntime`/`VersionRuntime` with concrete defaults). Keep seam override capability in tests via constructor injection instead of mutable package globals.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T13:23:44+00:00",
      "last_seen": "2026-03-01T13:23:44+00:00",
