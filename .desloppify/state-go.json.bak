    "review::.::holistic::abstraction_fitness::service_bootstrap_template_duplication::7b2fea81": {
      "id": "review::.::holistic::abstraction_fitness::service_bootstrap_template_duplication::7b2fea81",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Container bootstrap implementations repeat the same skeleton without a shared abstraction.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "goseg/docker/wireguard.go",
          "goseg/docker/netdata.go",
          "goseg/docker/minio.go"
        ],
        "evidence": [
          "`LoadWireguard` and `LoadNetdata` both implement: check/open config file, create default if missing, write generated config, start container, update container state.",
          "`LoadMC` in `goseg/docker/minio.go` applies the same startup skeleton with minor policy differences (registration gate and names).",
          "The repeated skeleton causes policy and error-handling behavior to be scattered across multiple loaders rather than represented as one reusable boot contract."
        ],
        "suggestion": "Create a shared loader pipeline abstraction (for example `bootService(spec)` with hooks for preconditions, default-file creation, config materialization, container start, and state update) and migrate wireguard/netdata/mc loaders to it.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
