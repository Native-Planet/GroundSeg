    "review::.::holistic::design_coherence::minio_service_account_brittle_command_gate::5e94a2ff": {
      "id": "review::.::holistic::design_coherence::minio_service_account_brittle_command_gate::5e94a2ff",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "MinIO account bootstrap is coupled to CLI response text and fails when expected phrasing differs.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/docker/orchestration/minio.go",
          "goseg/shipworkflow/urbit_operations.go"
        ],
        "evidence": [
          "`setMinIOAdminAccountWithRuntime` removes an existing service account and only proceeds to add a new one if command output contains `\"successfully\"`.",
          "`createMinIOServiceAccount` callers (e.g., `toggleMinIOLink`) interpret this as fatal and cannot enable integration when removal output format differs or no prior account exists."
        ],
        "suggestion": "Parse exit codes from `mc` commands directly and make creation idempotent: treat \"not found\" as non-fatal, attempt add after remove (or create directly) and only fail on explicit command errors.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T18:19:05+00:00",
