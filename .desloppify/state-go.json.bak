    "review::.::holistic::design_coherence::custom_drive_resolution_duplicated::2ed1434c": {
      "id": "review::.::holistic::design_coherence::custom_drive_resolution_duplicated::2ed1434c",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Custom-drive detection/formatting logic is duplicated across new-ship and import entry points with diverging control flow.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/handler/handler.go",
          "goseg/handler/newship.go",
          "goseg/importer/importer.go"
        ],
        "evidence": [
          "`NewShipHandler` and `createUrbitShip` both walk `ListHardDisks()` and apply `/groundseg-<n>` regex checks.",
          "`OpenUploadEndpoint` in importer repeats the same mountpoint search but encodes result through `NeedsFormatting` and later formatting in `ensureUploadDriveReady`.",
          "The same domain rule (resolve selected drive to usable mountpoint/format requirement) is implemented in multiple places with different error/formatting behavior."
        ],
        "suggestion": "Extract a single drive-resolution service returning `{mountpoint, needsFormatting, validationError}` and use it from both new-ship and importer workflows so formatting and error semantics stay consistent.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T14:15:26+00:00",
