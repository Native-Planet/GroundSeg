    "review::.::holistic::abstraction_fitness::duplicate_runtime_seams::6d7f4659": {
      "id": "review::.::holistic::abstraction_fitness::duplicate_runtime_seams::6d7f4659",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Parallel runtime seam abstractions are redefined in multiple packages, creating maintenance drift and inconsistent dependency policy.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "goseg/routines/runtime_seams.go",
          "goseg/docker/orchestration/runtime_seams.go",
          "goseg/routines/docker.go"
        ],
        "evidence": [
          "`routines/runtime_seams.go` and `docker/orchestration/runtime_seams.go` both define base/runtime structs with duplicated function-pointer dependency members and constructor wiring over the same configuration-backed sources.",
          "`routines/docker.go` and orchestration modules each rely on these duplicated seams independently, so a policy or dependency change must be replicated across files instead of applied centrally."
        ],
        "suggestion": "Introduce a shared seam abstraction layer (for example a small `runtime_dependencies` package) with reusable builder helpers and a minimal cross-package interface for container orchestration/config/logging/test seams; wire package-specific fields as composed overlays instead of duplicating full runtime scaffolding.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-01T18:19:05+00:00",
