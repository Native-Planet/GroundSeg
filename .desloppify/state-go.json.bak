    "review::.::holistic::cross_module_architecture::upload_action_contract_split::95cf6eb5": {
      "id": "review::.::holistic::cross_module_architecture::upload_action_contract_split::95cf6eb5",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Upload action contract is split between service constants and handler switch logic.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/handler/upload.go",
          "goseg/uploadsvc/service.go",
          "README.md"
        ],
        "evidence": [
          "`goseg/uploadsvc/service.go` exports `SupportedActions()` and typed action constants, but `goseg/handler/upload.go` separately encodes routing behavior in its own `switch` over `uploadPayload.Payload.Action`.",
          "Adding a new action requires parallel edits in `SupportedActions`, handler `switch`, and README\u2019s required test matrix, which increases boundary drift risk."
        ],
        "suggestion": "Move action dispatch into `uploadsvc` (for example, a single `Execute(action, payload)` or action-handler map keyed by `Action`) so handler code only decodes transport input and forwards once; derive supported-actions from the same dispatch table.",
        "reasoning": ""
