      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Orchestration runtime files conflate interface contracts, DI assembly, and default infrastructure wiring, creating a mixed-responsibility seam layer.",
      "detail": {
        "holistic": true,
