    "review::.::holistic::cross_module_architecture::contract_boundary_by_convention::64a6fbea": {
      "id": "review::.::holistic::cross_module_architecture::contract_boundary_by_convention::64a6fbea",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Upload action contract boundaries are enforced by convention/tests instead of a shared compile-time interface, creating drift-prone cross-module coupling.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/protocol/contracts/governance/upload_manifest.go",
          "goseg/uploadsvc/actions_test.go",
          "goseg/uploadsvc/doc.go",
          "goseg/protocol/contracts/conformance/fixtures_action_test.go"
        ],
        "evidence": [
          "governance/upload_manifest.go declares upload action strings and contract IDs independently in the governance package.",
          "uploadsvc/actions_test.go verifies local parsing/validation paths without asserting equivalence against governance declarations.",
          "uploadsvc/doc.go explicitly relies on canonical governance files via documentation, signaling a convention-based boundary.",
          "fixtures_action_test.go provides centralized parity checks for fixture/binding catalogs, but this does not remove duplicate contract vocabulary across module boundaries."
        ],
        "suggestion": "Introduce a single shared contract surface for action identifiers and payload policy metadata (e.g., typed declarations exported from a neutral contracts package) that both governance manifests and uploadsvc consume directly. Keep conformance tests as regression guards, but move source-of-truth ownership to one compile-time dependency path and generate/package-local views from it.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
