    "review::.::holistic::abstraction_fitness::callback_bag_runtime_overreach::505c3b04": {
      "id": "review::.::holistic::abstraction_fitness::callback_bag_runtime_overreach::505c3b04",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Large callback-bag runtime structs add indirection with weak domain leverage.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "goseg/startuporchestrator/startup_orchestrator.go",
          "goseg/importer/importer.go",
          "goseg/docker/orchestration/runtime_ops.go",
          "goseg/startuporchestrator/startup_orchestrator_test.go",
          "goseg/docker/orchestration/wireguard_test.go"
        ],
        "evidence": [
          "`startuporchestrator` composes startup runtime from multiple embedded callback structs and maps service-name enums to callback fields, creating orchestration-by-field-name instead of stable service interfaces.",
          "`importerRuntime` embeds storage/upload/provision callback groups with many function fields and repeated validation groups, indicating runtime shape is acting as a generic dependency bag.",
          "`runtime_ops.go` defines many `Runtime*Ops` structs and seam builders that mostly forward package-level functions into function fields.",
          "Tests need extensive option builders and callback overrides to exercise behavior, which indicates high abstraction ceremony and low leverage from these runtime surfaces."
        ],
        "suggestion": "Refactor callback bags into smaller behavior-oriented interfaces owned by use-case boundaries (for example `TransitionPublisher`, `ContainerProvisioner`, `StartupServiceRunner`). Keep only a minimal composition root that adapts concrete packages to those interfaces; remove field-by-field callback maps and service-name switch dispatch.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-05T16:57:36+00:00",
