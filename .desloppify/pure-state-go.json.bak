      "id": "review::.::holistic::abstraction_fitness::runtime_callback_bag_sprawl::d7337474",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Runtime callback-bag layering is over-fragmented and adds indirection without stable domain boundaries.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "goseg/startuporchestrator/startup_orchestrator.go",
