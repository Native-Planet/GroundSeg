    "review::.::holistic::error_consistency::legacy_backup_loops_silently_discard_worker_errors::42881c0e": {
      "id": "review::.::holistic::error_consistency::legacy_backup_loops_silently_discard_worker_errors::42881c0e",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Legacy backup loops swallow routine errors while sibling context loops propagate them",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "goseg/routines/system/system.go",
          "goseg/routines/system/system_test.go"
        ],
        "evidence": [
          "runRoutine() executes `fn()` as `_ = fn()` in an infinite loop, dropping all errors with no logging or escalation.",
          "TlonBackupRemote() and TlonBackupLocal() rely on runRoutine(), while RunBackupRoutinesWithContext()/runRoutineWithContext() return errors immediately on failure.",
          "Tests focus on context APIs and cancellation behavior, leaving the non-context silent-failure path unguarded."
        ],
        "suggestion": "Unify backup/chop loop error contract: either route legacy entry points through context-based loops with explicit error handling, or at minimum add structured logging and a retry/failure budget in runRoutine(); add tests that inject failing backup functions and assert observable failure behavior.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-05T17:28:56+00:00",
