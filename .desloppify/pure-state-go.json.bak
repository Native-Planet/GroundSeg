    "review::.::holistic::initialization_coupling::mutable_global_runtime_singletons::35cf573e": {
      "id": "review::.::holistic::initialization_coupling::mutable_global_runtime_singletons::35cf573e",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Global mutable default runtimes create boot-order and test-order coupling",
      "detail": {
        "holistic": true,
        "dimension": "initialization_coupling",
        "related_files": [
          "goseg/docker/events/events.go",
          "goseg/broadcast/state.go",
          "goseg/broadcast/loop.go",
          "goseg/docker/orchestration/subsystem/subsystem_events.go"
        ],
        "evidence": [
          "Each module exposes package-level default runtime state plus mutators (`SetDefault*`), allowing runtime behavior changes outside composition root.",
          "`Start*` entrypoints often implicitly read defaults, so effective dependencies vary based on prior global mutations.",
          "This pattern makes initialization order part of correctness and can cause cross-test leakage when defaults are replaced."
        ],
        "suggestion": "Move default-runtime wiring to explicit composition at startup (main/startup orchestrator) and pass runtime instances through constructors/functions; keep package globals only as backward-compatible shims that delegate to injected instances.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-05T14:06:44+00:00",
      "last_seen": "2026-03-05T14:06:44+00:00",
