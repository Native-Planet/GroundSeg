    "review::.::holistic::cross_module_architecture::policy_duplication_across_catalog_docs_tests::a6cf3794": {
      "id": "review::.::holistic::cross_module_architecture::policy_duplication_across_catalog_docs_tests::a6cf3794",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Upload action policy is duplicated across catalog constants, docs, and tests instead of one executable boundary.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/protocol/contracts/catalog/action/specs.go",
          "goseg/uploadsvc/doc.go",
          "goseg/uploadsvc/actions_test.go"
        ],
