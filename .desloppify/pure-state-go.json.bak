    "review::.::holistic::design_coherence::runtime_ops_aggregate_god_runtime::181246d1": {
      "id": "review::.::holistic::design_coherence::runtime_ops_aggregate_god_runtime::181246d1",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Orchestration runtime dependency wiring is over-aggregated, forcing unrelated concerns through one broad runtime shape.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/docker/orchestration/runtime_core.go",
          "goseg/docker/orchestration/runtime_ops.go",
          "goseg/startuporchestrator/startup_orchestrator_test.go"
        ],
        "evidence": [
          "`Runtime` embeds `RuntimeContainerOps`, `RuntimeUrbitOps`, `RuntimeSnapshotOps`, `RuntimeHealthOps`, `RuntimeStartupOps`, and `RuntimeStartramOps`, then merges all of them through shared options and dependency constructors.",
          "`buildRuntimeSeamBundle` and `defaultRuntime*` builders wire multiple subsystem dependencies (network/config/click/startram/file/image) in one central construction path.",
          "Tests in startup orchestration construct wide runtime override helpers to target behavior, indicating high setup breadth caused by the broad runtime dependency surface."
        ],
        "suggestion": "Split runtime dependency containers by bounded workflow (for example: startup runtime, container lifecycle runtime, startram runtime, health runtime) and provide narrower constructors/options so each call path receives only the operations it needs.",
