    "review::.::holistic::cross_module_architecture::distributed_contract_conformance_checks::32559341": {
      "id": "review::.::holistic::cross_module_architecture::distributed_contract_conformance_checks::32559341",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Contract conformance logic is split across conformance and feature tests, creating boundary drift risk.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/protocol/contracts/conformance/fixtures_test.go",
          "goseg/uploadsvc/actions_test.go"
        ],
        "evidence": [
          "`fixtures_test.go` validates fixture\u2194binding parity (`TestActionContractFixturesMatchCanonicalBindings`, lines 31-65) and upload payload-rule presence (`TestUploadActionBindingSpecsExposePayloadRules`, lines 88-109).",
          "`actions_test.go` independently validates upload action\u2194contract parity (`TestUploadParserActionsMatchUploadContractRegistry`, lines 38-79) and payload-rule behavior matrix (`TestUploadActionBindingsValidateRuntimePayloadRules`, lines 96-155).",
          "Both tests derive expectations from `contracts.UploadActionBindingSpecs()` but keep separate assertion logic, so policy changes require synchronized edits in two packages."
        ],
        "suggestion": "Consolidate contract-governance assertions under `protocol/contracts/conformance` as reusable helpers (or a shared conformance matrix), then have `uploadsvc` keep only behavior-specific integration checks. This preserves a single architectural boundary for protocol-policy verification.",
        "reasoning": ""
