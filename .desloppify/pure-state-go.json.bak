    "review::.::holistic::cross_module_architecture::split_contract_governance_surfaces::42f0fda2": {
      "id": "review::.::holistic::cross_module_architecture::split_contract_governance_surfaces::42f0fda2",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Contract governance responsibility is split across catalog, conformance tests, and uploadsvc policy docs.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/protocol/contracts/catalog/action/specs.go",
          "goseg/protocol/contracts/catalog/startram/specs.go",
          "goseg/protocol/contracts/conformance/fixtures_test.go",
          "goseg/uploadsvc/actions_test.go",
          "goseg/uploadsvc/doc.go"
        ],
        "evidence": [
          "Catalog packages define canonical IDs/specs (`specs.go` files), but enforcement is duplicated in both `protocol/contracts/conformance` and `uploadsvc` tests.",
          "`uploadsvc/doc.go` states canonical governance policy location, yet uploadsvc tests still encode cross-package registry invariants (`contracts.UploadActionBindingSpecs`, contract metadata, payload rules).",
          "This creates multiple architectural control points for one contract boundary, increasing blast radius for any contract model change."
        ],
        "suggestion": "Create a single governance verification surface under `protocol/contracts` (e.g., exported conformance helpers or shared fixture assertions) and have `uploadsvc` tests consume that API for boundary checks while keeping uploadsvc-local behavior tests only for parser/validator behavior.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
      "first_seen": "2026-03-05T14:18:51+00:00",
      "last_seen": "2026-03-05T14:18:51+00:00",
