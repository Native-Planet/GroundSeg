    "review::.::holistic::abstraction_fitness::global_runtime_broker_coupling::569e88d7": {
      "id": "review::.::holistic::abstraction_fitness::global_runtime_broker_coupling::569e88d7",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Event broker abstraction leaks through mutable process-global defaults across subsystems.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "goseg/docker/events/events.go",
          "goseg/shipworkflow/operations_runtime.go",
          "goseg/importer/importer.go",
          "goseg/startuporchestrator/startup_orchestrator.go"
        ],
        "evidence": [
          "`events.NewGlobalDefaultBroker()` returns a broker that resolves against `DefaultEventRuntime()` on each call.",
          "`shipworkflow.newWorkflowRuntime()` wires `EventRuntime` and transition publishing to `events.NewGlobalDefaultBroker()` rather than a scoped broker instance.",
          "`importer.defaultImporterRuntime()` publishes import transitions through `events.NewGlobalDefaultBroker()`.",
          "Startup wiring starts many long-lived subsystems, so shared mutable defaults become hidden cross-subsystem coupling instead of explicit dependency wiring."
        ],
        "suggestion": "Promote `events.EventBroker` to an explicit startup dependency and thread it through startup orchestrator into importer/workflow constructors. Keep `NewGlobalDefaultBroker` only as a compatibility adapter at process edge, and make core paths depend on injected broker instances.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "Disappeared from scan \u2014 likely fixed",
