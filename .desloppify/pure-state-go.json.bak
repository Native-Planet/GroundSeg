      "tier": 3,
      "confidence": "medium",
      "summary": "Config patch registry is built at import time and hard-coupled to package init order",
      "detail": {
        "holistic": true,
        "dimension": "initialization_coupling",
        "related_files": [
          "goseg/config/config_update_schema.go",
