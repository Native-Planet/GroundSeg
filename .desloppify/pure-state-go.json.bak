    "review::.::holistic::cross_module_architecture::split_contract_governance_surfaces::42f0fda2": {
      "id": "review::.::holistic::cross_module_architecture::split_contract_governance_surfaces::42f0fda2",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Contract governance responsibility is split across catalog, conformance tests, and uploadsvc policy docs.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/protocol/contracts/catalog/action/specs.go",
          "goseg/protocol/contracts/catalog/startram/specs.go",
          "goseg/protocol/contracts/conformance/fixtures_test.go",
          "goseg/uploadsvc/actions_test.go",
          "goseg/uploadsvc/doc.go"
        ],
        "evidence": [
          "Catalog packages define canonical IDs/specs (`specs.go` files), but enforcement is duplicated in both `protocol/contracts/conformance` and `uploadsvc` tests.",
          "`uploadsvc/doc.go` states canonical governance policy location, yet uploadsvc tests still encode cross-package registry invariants (`contracts.UploadActionBindingSpecs`, contract metadata, payload rules).",
          "This creates multiple architectural control points for one contract boundary, increasing blast radius for any contract model change."
        ],
        "suggestion": "Create a single governance verification surface under `protocol/contracts` (e.g., exported conformance helpers or shared fixture assertions) and have `uploadsvc` tests consume that API for boundary checks while keeping uploadsvc-local behavior tests only for parser/validator behavior.",
        "reasoning": ""
      },
      "status": "fixed",
      "note": "Moved upload contract registry/payload-rule conformance assertions out of uploadsvc tests into protocol/contracts/conformance as the single cross-package governance surface.",
      "first_seen": "2026-03-05T14:18:51+00:00",
      "last_seen": "2026-03-05T14:18:51+00:00",
      "resolved_at": "2026-03-05T14:23:49+00:00",
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
        "kind": "manual",
        "text": "I have actually consolidated cross-package contract conformance tests under protocol/contracts/conformance and reduced duplicate governance checks in uploadsvc, and I am not gaming the score by resolving without fixing.",
        "attested_at": "2026-03-05T14:23:49+00:00",
        "scan_verified": false
      }
    },
    "review::.::holistic::cross_module_architecture::string_prefix_boundary_detection::e5b34302": {
      "id": "review::.::holistic::cross_module_architecture::string_prefix_boundary_detection::e5b34302",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Startram boundary validation relies on string-prefix scanning instead of explicit typed membership.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "goseg/protocol/contracts/conformance/fixtures_test.go",
          "goseg/protocol/contracts/catalog/startram/specs.go"
        ],
        "evidence": [
          "`TestStartramContractSpecsMatchCanonicalCatalog` builds a prefix from family/scope constants and filters `contracts.ContractCatalogEntries()` with `strings.HasPrefix`.",
          "The test asserts module ownership by ID text shape (`startram.errors.*`) rather than by explicit catalog grouping API, so taxonomy renames alter boundary semantics across modules."
        ],
        "suggestion": "Expose explicit family-scoped catalog accessors (e.g., `contracts.StartramContractEntries()` or typed family tags) and update conformance tests to validate through that boundary, removing architectural dependence on ID string format.",
        "reasoning": ""
