      "id": "review::.::holistic::error_consistency::broadcast_runtime_error_type_drift::9d5f4bc5",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Broadcast runtime precondition failures use incompatible error identities, making failure handling non-uniform.",
