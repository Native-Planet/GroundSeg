      "id": "review::.::holistic::design_coherence::runtime_singleton_lifecycle_mixed_with_domain_ops::bd02b603",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Runtime domain APIs also own process-global singleton lifecycle, blurring module responsibility boundaries.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "goseg/broadcast/state.go",
          "goseg/docker/events/events.go"
        ],
        "evidence": [
          "goseg/broadcast/state.go defines state mutation/query behavior and also process-global runtime storage + mutators (`defaultBroadcastStateRuntime`, `DefaultBroadcastStateRuntime`, `SetDefaultBroadcastStateRuntime`, `ResetDefaultBroadcastStateRuntime`).",
          "goseg/docker/events/events.go follows the same pattern with event publish/subscribe behavior plus mutable global default runtime (`defaultEventRuntime`, `DefaultEventRuntime`, `SetDefaultEventRuntime`, `ResetDefaultEventRuntime`).",
          "This repeats a structural pattern where runtime logic and app-global lifecycle policy are co-located, making the same files change for unrelated reasons."
        ],
        "suggestion": "Extract singleton lifecycle ownership into dedicated runtime-provider files (e.g., `*_runtime_default.go`) and keep runtime types/files focused on pure event/state operations. Keep `Default/Set/Reset` wrappers thin and isolated so domain modules no longer carry global lifecycle policy.",
        "reasoning": ""
      },
