func (runtime startramRuntime) HandleStartramCancel(key string, reset bool) error {
	if reset {
		for _, svc := range runtime.getStartramConfigFn().Subdomains {
			if err := runtime.svcDeleteFn(svc.URL, svc.SvcType); err != nil {
				zap.L().Error(fmt.Sprintf("Couldn't delete service %v: %v", svc.URL, err))
			}
		}
	}
	if err := startram.CancelSub(key); err != nil {
		publishStartramError(string(transition.StartramTransitionCancel), fmt.Sprintf("Couldn't cancel subscription: %v", err), true)
		return fmt.Errorf("cancel subscription: %w", err)
	}
	if err := runtime.cycleWgKeyFn(); err != nil {
		publishStartramError(string(transition.StartramTransitionCancel), fmt.Sprintf("%v", err), true)
		return fmt.Errorf("cycle wireguard key: %w", err)
	}
	publishStartramCompletion(string(transition.StartramTransitionCancel), nil)
	return nil
}

