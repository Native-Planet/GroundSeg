func ListWifiSSIDsWithRuntime(runtime wifiRuntime, dev string) ([]string, error) {
	runtime = withWiFiRuntime(runtime)
	out, err := runCommandWithRuntime(runtime, "nmcli", "-t", "dev", "wifi", "list", "ifname", dev)
	if err != nil {
		return nil, fmt.Errorf("couldn't gather wifi networks: %w", err)
	}
	lines := strings.Split(out, "\n")
	var ssids []string
	for _, line := range lines {
		parts := strings.Split(line, ":")
		if len(parts) > 7 && parts[7] != "" {
			ssids = append(ssids, parts[7])
		}
	}
	return ssids, nil
}

func getConnectedSSID(c *wifi.Client, dev string) (string, error) {
	return getConnectedSSIDWithRuntime(defaultWiFiRuntime(), c, dev)
