  "findings": [
    {
      "dimension": "design_coherence",
      "identifier": "config_schema_split_brain",
      "summary": "Config domain is duplicated across persistence and patch schemas, creating a split-brain model that is easy to drift.",
      "related_files": [
        "goseg/structs/configs.go",
        "goseg/config/config_update_schema.go",
        "goseg/config/config_test.go"
      ],
      "evidence": [
        "`SysConfig` and section structs are defined in `structs/configs.go` while patch equivalents (`ConnectivityPatch`, `RuntimePatch`, etc.) are separately defined in `config_update_schema.go`.",
        "Field-level policy differences are encoded manually (e.g., pointer-based optionality in patch structs vs value structs in persisted config), requiring hand-maintained correspondence.",
        "Large merge tests in `config_test.go` assert many per-field behaviors, indicating high synchronization burden when config shape changes."
      ],
      "suggestion": "Define a single canonical config field map (or generated schema descriptors) and derive both persisted structs and patch/update behavior from it; at minimum, centralize field metadata and validation rules so additions/removals happen in one place.",
      "confidence": "high",
      "impact_scope": "subsystem",
      "fix_scope": "architectural_change",
      "root_cause_cluster": "duplicated_domain_modeling"
    },
    {
      "dimension": "design_coherence",
      "identifier": "runtime_callback_bag_growth",
      "summary": "Orchestration runtime relies on large callback bags plus repetitive merge/delegate glue, reducing cohesion and increasing indirection cost.",
      "related_files": [
        "goseg/docker/orchestration/runtime_core.go",
        "goseg/docker/orchestration/runtime_ops.go",
        "goseg/docker/lifecycle/lifecycle_full_test.go"
      ],
      "evidence": [
        "`Runtime` composes six operation bags, then `runtime_core.go` adds multiple wrapper methods with nil checks and fallback behavior.",
        "`runtime_ops.go` defines many callback fields across container/urbit/snapshot/health/startup/startram concerns in one subsystem-level dependency object.",
