func (runtime *broadcastStateRuntime) GetState() structs.AuthBroadcast {
	if runtime == nil {
		return structs.AuthBroadcast{}
	}
	runtime.RLock()
	defer runtime.RUnlock()
	return cloneBroadcastState(runtime.broadcastState)
