func prepareSupportWorkspace(rt supportRuntime, timestamp string) (string, error) {
	reportRoot, err := rt.reportRootPath()
	if err != nil {
		return "", err
	}
	bugReportDir := filepath.Join(reportRoot, timestamp)
	if err := rt.mkdirAllFn(bugReportDir, 0755); err != nil {
		return "", err
	}
	return bugReportDir, nil
}

