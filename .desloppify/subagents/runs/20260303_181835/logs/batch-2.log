    {
      "dimension": "design_coherence",
      "identifier": "config_patch_stringly_reflection_bridge",
      "summary": "Config patch registry relies on string field names plus reflection, creating a brittle cross-file contract instead of a coherent typed boundary.",
      "related_files": [
        "goseg/config/config_update_registry.go",
        "goseg/config/config_update_schema.go"
      ],
      "evidence": [
        "`configPatchFieldFromSpec` definitions pass `patchField` strings (for example in `runtimePatchFields` and other domain field lists), then `patchFieldRefByName` resolves values indirectly.",
        "`getConfigPatchValueByName` and `setConfigPatchValueByName` use `reflect.ValueOf(...).Elem().FieldByName(field)`, so compile-time renames of `ConfPatch` fields do not fail at compile time and can silently change behavior."
      ],
      "suggestion": "Replace string-based field resolution with typed accessors for every patch field (using `confPatchPointerRef`/`confPatchValueAccessor` only), and remove `FieldByName` usage so schema and registry remain compile-time linked.",
      "confidence": "high",
      "impact_scope": "subsystem",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "stringly_typed_update_plumbing"
    },
    {
      "dimension": "design_coherence",
      "identifier": "runtime_ops_god_module",
      "summary": "The orchestration runtime ops module mixes many unrelated seam domains and default wiring paths in one file, reducing cohesion and increasing change coupling.",
      "related_files": [
        "goseg/docker/orchestration/runtime_ops.go",
        "goseg/system/wifi_runtime_api.go"
