      "impact_scope": "subsystem",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "contract_catalog_governance"
    }
  ],
  "retrospective": {
    "root_causes": [
      "No enforced package-level convention for immutable contract identity and catalog assembly.",
      "Contract registry relies on file-local mutable globals rather than a single canonical construction path."
    ],
    "likely_symptoms": [
      "mutable_exported_contract_id",
      "inconsistent_contract_catalog_pattern"
