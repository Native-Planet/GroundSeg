package config

import "groundseg/structs"

func applyConfigMutation[T any, Domain any](
	selectDomain func(*structs.SysConfig) *Domain,
	apply func(*Domain, T),
) confPatchApplyValueFn[T] {
	return func(target confPatchApplyTarget, value T) {
		if target == nil {
			return
		}
		domain := selectDomain(target)
		if domain == nil {
			return
		}
		apply(domain, value)
	}
}


