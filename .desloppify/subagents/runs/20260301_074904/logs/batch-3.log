export const daysUntilDate = (dateString) => {
  const targetDate = new Date(dateString);
  const currentDate = new Date();
  const diffTime = Math.abs(targetDate - currentDate);
  const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
  return diffDays;
};
