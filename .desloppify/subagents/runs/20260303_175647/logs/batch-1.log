      "identifier": "oversized_callback_bag_di",
      "summary": "Function-pointer runtime bags have become wide pseudo-interfaces, signaling under-modeled domain boundaries.",
      "related_files": [
        "goseg/importer/importer.go",
        "goseg/startuporchestrator/startup_orchestrator.go",
