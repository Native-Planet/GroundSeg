  "findings": [
    {
      "dimension": "design_coherence",
      "identifier": "broadcast_state_ownership_mismatch",
      "summary": "Broadcast state writer stores caller-owned references while readers get clones, allowing external mutation of internal state.",
      "related_files": [
        "goseg/broadcast/state.go",
        "goseg/broadcast/loop_test.go"
      ],
      "evidence": [
        "`UpdateBroadcast` assigns `runtime.broadcastState = next` directly (no defensive copy).",
        "`GetState` returns `cloneBroadcastState(runtime.broadcastState)` for caller-safe reads, creating a write-vs-read ownership mismatch.",
        "This pattern is fragile in concurrent flows where the same state object may be mutated after `UpdateBroadcast` by caller code."
      ],
      "suggestion": "Clone the incoming state in `UpdateBroadcast` before storing, e.g. `runtime.broadcastState = cloneBroadcastState(next)`, and optionally add regression tests that mutate the caller-owned payload after update to assert runtime state remains unchanged.",
      "confidence": "high",
      "impact_scope": "module",
      "fix_scope": "single_edit",
      "root_cause_cluster": "state_ownership_boundary"
    },
    {
      "dimension": "design_coherence",
      "identifier": "global_test_state_fragmentation",
      "summary": "Tests are tightly coupled to package-level globals, creating brittle, mixed-responsibility fixtures across modules.",
      "related_files": [
        "goseg/accesspoint/accesspoint_test.go",
        "goseg/importer/importer_test.go",
        "goseg/leak/handler_test.go"
      ],
      "evidence": [
        "`accesspoint_test.go` defines multiple global-state restoration helpers (`resetParameterGlobalsForTest`, `resetRouterGlobalsForTest`) and mutates globals such as `wlan`, `inet`, `ip`, `password`, and runtime function vars.",
        "`importer_test.go` uses package-wide helpers like `resetUploadSessionsForTest` and direct seam mutation around `uploadSessions` for each test.",
        "`leak/handler_test.go` drives behavior by mutating shared global maps/channels and relies on global resets (`resetLeakStateForTest`)."
      ],
      "suggestion": "Introduce explicit fixture builders/runtime structs for tests and replace direct global mutation with constructor-injected seams (or context-bound test doubles) so each test owns isolated, composable state and setup/teardown is declarative rather than global.",
      "confidence": "medium",
      "impact_scope": "subsystem",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "global_state_test_hardness"
    }
  ],
  "retrospective": {
    "root_causes": [
      "asymmetric state ownership boundaries in runtime containers",
      "global mutable fixtures instead of injectable, isolated test seams"
    ],
    "likely_symptoms": [
      "non-deterministic broadcast updates under concurrent callers",
      "fragile test order dependencies and hidden cross-test coupling"
    ],
    "possible_false_positives": [
      "The test-fixture global-state issue is most visible in tests and may be partially intentional for these integration-style suites."
