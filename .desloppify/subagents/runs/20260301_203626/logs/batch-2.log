func scheduleShipRestart(rt dockerRoutineRuntime, containerName, containerType string) error {
	zap.L().Info(fmt.Sprintf("Attempting to restart ship %s after death", containerName))
	go func(name, ctype string) {
		rt.timer.Sleep(2 * time.Second)
		_, err := rt.containerOps.StartContainer(name, ctype)
		if err != nil {
			zap.L().Error(fmt.Sprintf("Failed to restart %s after death: %v", name, err))
			return
		}
		zap.L().Info(fmt.Sprintf("Successfully restarted %s after death", name))
	}(containerName, containerType)
	return nil
}

