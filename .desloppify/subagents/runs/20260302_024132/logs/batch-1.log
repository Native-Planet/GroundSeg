      "dimension": "cross_module_architecture",
      "identifier": "boundary-protocol-shim-redundancy",
      "summary": "Shared protocol action contracts are duplicated through thin alias/wrapper layers in multiple transport/service modules, increasing coupling and weakening module boundaries.",
      "related_files": [
        "goseg/protocol/actions/actions.go",
