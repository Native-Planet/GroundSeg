import { loadSession } from './gs-crypto'
import { writable } from 'svelte/store'

export let logs = writable({})
let SESSION = {};
let lastLogMessageParseErrorAt = 0

export const safeParseLogSocketMessage = raw => {
  try {
    return JSON.parse(raw)
  } catch (error) {
    const now = Date.now()
    if (now - lastLogMessageParseErrorAt > 5000) {
      console.error("Failed to parse log websocket message", error)
      lastLogMessageParseErrorAt = now
    }
    return null
  }
}

