func captureCPUProfile(filename string) error {
	f, err := os.Create(filename)
	if err != nil {
		return err
	}
	defer f.Close()
	zap.L().Info("Profiling CPU for 30 seconds")
	if err := pprof.StartCPUProfile(f); err != nil {
		return err
	}
	time.Sleep(30 * time.Second)
	pprof.StopCPUProfile()
	return nil
}

