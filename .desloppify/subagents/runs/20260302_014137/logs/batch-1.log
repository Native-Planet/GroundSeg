    {
      "dimension": "cross_module_architecture",
      "identifier": "cm-001",
      "summary": "WireGuard config module mixes transport/version policy, schema translation, and persistence in one hub, creating avoidable cross-module coupling.",
      "related_files": [
        "goseg/config/wireguard.go"
      ],
      "evidence": [
        "Runtime wiring in `wireguardRuntime` includes cross-domain dependencies: `getConf`, `getVersionChannel`, `getWgKeypair`, `updateConfTyped`.",
        "`updateWGConf` obtains channel metadata and directly emits a concrete `structs.WgConfig`, then writes JSON to `wgConfigPath`, tying runtime version contracts to concrete storage logic.",
        "`WgKeyGen` in the same file calls `wgtypes.GeneratePrivateKey`, mixing cryptographic key operations with config persistence and update orchestration."
      ],
      "suggestion": "Split responsibilities into at least two packages/interfaces: one package for WireGuard config persistence (read/write path + schema marshaling), and one for domain adaptation/service orchestration that maps version/channel info to config models. Inject interfaces at call sites so config format changes and WireGuard crypto details do not force broad rewiring in unrelated modules.",
      "confidence": "medium",
      "impact_scope": "module",
      "fix_scope": "architectural_change",
      "root_cause_cluster": "cross-module_hub_module"
    }
  ],
  "retrospective": {
    "root_causes": [
      "Hub module concentration: multiple responsibilities merged into config package for convenience rather than explicit module boundaries."
    ],
    "likely_symptoms": [
      "cm-001"
    ],
