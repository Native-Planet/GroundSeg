func adaptCopyFileToVolumeFn(
	copyFileToVolumeFn func(string, string, string, string, volumeWriterImageSelector) error,
) func(string, string, string, string, func() (string, error)) error {
	if copyFileToVolumeFn == nil {
		return nil
	}
	return func(path string, target string, volume string, writer string, selectImage func() (string, error)) error {
		return copyFileToVolumeFn(path, target, volume, writer, func() (string, error) {
			return selectImage()
		})
	}
}
