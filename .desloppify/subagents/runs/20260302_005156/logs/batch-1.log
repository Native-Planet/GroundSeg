      "identifier": "upload-action-contract-overfitted",
      "summary": "Upload action contract is represented as weakly-typed flags, making action intent and payload rules easy to drift apart across layers.",
      "related_files": [
        "goseg/protocol/actions/actions.go",
        "goseg/uploadsvc/service_test.go"
      ],
