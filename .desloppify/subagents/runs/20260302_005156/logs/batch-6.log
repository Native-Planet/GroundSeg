func prepareShipForPackMeld(patp string, wasRunning bool) error {
	setContainerDesiredStatus(patp, "stopped")
	if !wasRunning {
		return nil
	}
	if err := click.BarExit(patp); err != nil {
		zap.L().Error(fmt.Sprintf("Failed to stop ship with |exit for pack & meld %s: %v", patp, err))
		if err = orchestration.StopContainerByName(patp); err != nil {
			zap.L().Error(fmt.Sprintf("Failed to stop ship for pack & meld %s: %v", patp, err))
		}
	}
	if err := WaitComplete(patp); err != nil {
		return fmt.Errorf("Failed waiting for stop completion on %s before pack & meld: %w", patp, err)
	}
	return nil
}

