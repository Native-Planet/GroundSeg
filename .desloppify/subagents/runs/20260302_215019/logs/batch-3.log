      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "contract_governance_not_machine_enforced"
    }
  ],
  "retrospective": {
    "root_causes": [
      "Governance rules are primarily documented in README, but enforcement is not fully encoded in contract declaration APIs/constraints.",
      "Contract declaration style mixes stable identity metadata with exportable presentation strings, weakening boundary integrity."
    ],
