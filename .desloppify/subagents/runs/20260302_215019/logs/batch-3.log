      "dimension": "cross_module_architecture",
      "identifier": "message_text_leaks_across_boundary",
      "summary": "StarTram error contract exports raw message text, encouraging cross-module coupling to presentation strings instead of stable contract IDs.",
      "related_files": [
        "README.md",
        "goseg/protocol/contracts/startram_contracts.go"
      ],
      "evidence": [
        "startram_contracts.go exports APIConnectionErrorMessage as a package-level untyped string constant.",
