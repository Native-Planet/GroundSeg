package config

func UpdateConfTyped(opts ...ConfUpdateOption) error {
	if len(opts) == 0 {
		return nil
	}

	patch := &ConfPatch{}
	for _, opt := range opts {
		if opt != nil {
			opt(patch)
		}
	}
	if !patch.hasUpdates() {
		return nil
	}

	return updateConfFromPatch(patch)
}

