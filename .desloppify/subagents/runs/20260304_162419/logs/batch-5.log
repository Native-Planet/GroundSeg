  "findings": [
    {
      "dimension": "error_consistency",
      "identifier": "context_loss_in_parsers_and_artifact_io",
      "summary": "Multiple boundary functions drop error cause/context, producing hard-to-trace failures.",
      "related_files": [
        "goseg/importer/importer.go",
        "goseg/docker/orchestration/internal/artifactwriter/artifact_writer.go"
      ],
      "evidence": [
        "`parseUploadChunkMetadata` returns `fmt.Errorf(\"invalid chunk index\")` and `fmt.Errorf(\"invalid total chunk count\")` after `strconv.Atoi` failures, discarding both source error and raw input.",
        "`EnsureContainerVolumes` and `TarArchiveForSingleFile` return raw errors (`return err`) for several failure points (volume existence/create, open/stat/copy/close), so callers often lose operation/file context."
      ],
      "suggestion": "Standardize boundary wrapping: include operation + key identifiers (file path, volume name, input field/value) and preserve root causes with `%w` in both importer parsing and artifactwriter helpers.",
      "confidence": "high",
      "impact_scope": "subsystem",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "error_context_erosion"
    },
    {
      "dimension": "error_consistency",
      "identifier": "mixed_failure_policy_in_startup_paths",
      "summary": "Startup paths mix silent suppression, log-only handling, and propagated errors for similar lifecycle failures.",
      "related_files": [
        "goseg/startuporchestrator/startup_orchestrator.go",
        "goseg/main.go"
      ],
      "evidence": [
        "`runInitPhase` ignores non-required init errors without logging (`if task.required { return ... }` else no action), while `start` and `health` log optional failures via `logOptionalStartupFailure`.",
        "In `main.go`, `shutdownServers` logs shutdown failures and discards them, but the context-cancel shutdown branch collects and returns joined shutdown errors."
      ],
      "suggestion": "Define one explicit lifecycle error policy (required/optional/fail-fast classes), then enforce it uniformly: optional errors should at least emit structured telemetry, and comparable shutdown paths should either both propagate aggregated errors or both intentionally downgrade with documented rationale.",
