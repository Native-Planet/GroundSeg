    {
      "dimension": "mid_level_elegance",
      "identifier": "startup_optional_runtime_handoffs",
      "summary": "Startup runtime handoff uses implicit optional callbacks, so required subsystem initialization can be skipped without clear failure signal.",
      "related_files": [
        "goseg/startup_orchestrator.go",
        "goseg/docker/orchestration/runtime_seams.go"
      ],
      "evidence": [
        "`startBackgroundServices` in `startup_orchestrator.go` checks for nil before calling many runtime hooks and proceeds regardless of hook presence.",
        "`StartupRuntime` and related seam structs in `runtime_seams.go` expose many individually injected function fields, which lets callsites hide required dependency presence behind nil checks."
      ],
      "suggestion": "Introduce explicit required/optional service contracts in startup (e.g., typed interfaces plus mandatory registration validation), and fail fast when required hooks are missing while leaving truly optional services behind explicit flags.",
      "confidence": "high",
      "impact_scope": "subsystem",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "implicit_runtime_contracts"
    },
    {
      "dimension": "mid_level_elegance",
      "identifier": "urbit_conf_snapshot_stale_mutation",
      "summary": "URBIT config flow reads one snapshot, mutates config, then continues logic from stale snapshot values.",
      "related_files": [
        "goseg/docker/orchestration/urbit.go",
        "goseg/config/config.go"
