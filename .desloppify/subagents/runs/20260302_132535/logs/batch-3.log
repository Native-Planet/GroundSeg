      "dimension": "error_consistency",
      "identifier": "implicit_best_effort_without_policy",
      "summary": "Background/update and state-mutation paths mix fail-open and fail-fast handling without a shared policy, creating unpredictable failure modes.",
      "related_files": [
        "goseg/routines/version.go",
