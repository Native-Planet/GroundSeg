// The canonical action set is `actionBindings`; keep it as the source of truth for
// supported actions and dispatch behavior.
type OpenEndpointRequest struct {
	Endpoint      string
	TokenID       string
	TokenValue    string
	Remote        bool
	Fix           bool
	SelectedDrive string
}

