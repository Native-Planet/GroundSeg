package config

func UpdateConfigTyped(opts ...ConfigUpdateOption) error {
	if len(opts) == 0 {
		return nil
	}

	patch := &ConfigPatch{}
	for _, opt := range opts {
		if opt != nil {
			opt(patch)
		}
	}
	if !patch.hasUpdates() {
		return nil
	}

	return updateConfigFromPatch(patch)
}

