      "root_cause_cluster": "workflow_orchestration_duplication"
    },
    {
      "dimension": "design_coherence",
      "identifier": "global_singleton_state_pattern",
      "summary": "Extensive mutable package-level state creates implicit coupling and weakens coherent component boundaries.",
      "related_files": [
        "goseg/config/config.go",
        "goseg/docker/docker.go",
        "goseg/broadcast/broadcast.go",
        "goseg/system/wifi.go",
        "goseg/auth/auth.go",
        "goseg/importer/importer.go"
      ],
      "evidence": [
        "`config` exposes mutable globals (`globalConfig`, `GSContainers`, caches, mutexes) as shared runtime authority.",
        "`docker`, `broadcast`, `system`, `auth`, and `importer` each keep independent global mutable maps/channels/session registries used directly by handlers.",
