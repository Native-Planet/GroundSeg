  "findings": [
    {
      "dimension": "high_level_elegance",
      "identifier": "PKG-GLBCTX-001",
      "summary": "Global mutable config state is treated as the primary seam despite explicit runtime-context abstractions, creating mixed ownership and inconsistent boundaries.",
      "related_files": [
        "goseg/config/bootstrap.go",
        "goseg/config/config.go",
        "goseg/docker/orchestration/container_bridge.go"
      ],
      "evidence": [
        "`goseg/config/bootstrap.go` declares package-level mutable configuration variables (`BasePath`, `Architecture`, `DebugMode`, `Ready`, `DockerDir`) and updates process state during initialization.",
        "`goseg/config/config.go` introduces `RuntimeContext` and `RuntimeContextSnapshot` specifically to pass execution context explicitly.",
        "`goseg/docker/orchestration/container_bridge.go:20` still reads `config.DockerDir` directly inside `llamaRuntimeFromGlobals`, bypassing that explicit context channel."
      ],
      "suggestion": "Complete the migration to explicit context passing: make orchestration constructors accept a bounded runtime context interface/struct and remove `llamaRuntimeFromGlobals` global reads so initialization flows through dependency injection only.",
      "confidence": "high",
      "impact_scope": "subsystem",
      "fix_scope": "architectural_change",
      "root_cause_cluster": "global_config_context_mismatch"
    },
    {
      "dimension": "high_level_elegance",
      "identifier": "PKG-STRAT-002",
      "summary": "Orchestration container factory pattern is inconsistent: one runtime is built from globals while peers are built from composable op groups, reducing clarity of architectural contracts.",
      "related_files": [
        "goseg/docker/orchestration/container_bridge.go",
        "goseg/docker/orchestration/container_config.go"
      ],
      "evidence": [
        "`llamaRuntimeFromGlobals` (in `container_bridge.go`) depends on package globals and names itself as the outlier against other factories that take a `dockerRuntime` aggregate.",
        "The coexistence of this factory style with the `netdataRuntimeFromDocker`/`minioRuntimeFromDocker` patterns is not signaled by package-level naming or interface boundaries."
      ],
      "suggestion": "Align all container runtime constructors behind a single composition style (prefer injected runtime context + interfaces) and delete global-seeking constructor variants.",
      "confidence": "high",
      "impact_scope": "module",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "global_config_context_mismatch"
    },
    {
      "dimension": "high_level_elegance",
      "identifier": "PKG-STAR-003",
      "summary": "Startram adds redundant crypto passthrough functions instead of keeping a single domain boundary, increasing API confusion and package sprawl.",
      "related_files": [
        "goseg/startram/backup_crypto.go",
        "goseg/startram/backup_runtime_test.go",
        "goseg/startram/backup_restore_runtime.go"
      ],
      "evidence": [
        "`goseg/startram/backup_crypto.go` only wraps `backup.EncryptFile` and `backup.DecryptFile` without transformation.",
        "Tests in `backup_runtime_test.go` validate these local wrappers instead of importing the underlying backup API directly.",
        "Other backup restore logic in `backup_restore_runtime.go` already talks to the backup package directly for persistence and fetch operations, so the wrapper layer adds no coherent policy."
      ],
      "suggestion": "Use the `backup` package API directly in startram callers/tests and remove `backup_crypto.go`, keeping one clear cryptographic API owner.",
      "confidence": "high",
      "impact_scope": "module",
      "fix_scope": "single_edit"
    },
    {
      "dimension": "high_level_elegance",
      "identifier": "PKG-ORCH-004",
      "summary": "Redundant exported/unexported duplicate symbol pair in container config adds avoidable public API noise and signals unstable package ownership choices.",
      "related_files": [
        "goseg/docker/orchestration/container_config.go",
        "goseg/docker/orchestration/docker_test.go"
      ],
      "evidence": [
        "`ContainerConfigForType` and `containerConfigForType` are functionally identical, with the unexported version only delegating to the exported one.",
        "Tests and callsites gain no benefit from having both, yet maintainers must reason about two possible entry points."
      ],
      "suggestion": "Remove the unnecessary alias and keep a single canonical constructor name, updating any internal references accordingly.",
      "confidence": "medium",
      "impact_scope": "local",
      "fix_scope": "single_edit"
    }
  ],
  "retrospective": {
    "root_causes": [
      "Boundary erosion via package-level mutable state and partial migration to explicit runtime/context passing.",
      "API surface drift from thin, historical wrappers retained after moving responsibilities elsewhere."
    ],
    "likely_symptoms": [
      "PKG-GLBCTX-001",
      "PKG-STRAT-002",
      "PKG-STAR-003"
    ],
    "possible_false_positives": [
      "If `llamaRuntimeFromGlobals` is intentionally temporary pending larger initialization refactor, its current global usage may be by design, though it is still materially inconsistent with surrounding constructors."
    ]
  }
