package seams

import (
	"reflect"
	"unsafe"
)

func Merge[T any](base, overrides T) T {
	mergeValue(reflect.ValueOf(&base).Elem(), reflect.ValueOf(overrides))
	return base
}

func MergeAll[T any](base T, overrides ...T) T {
	merged := base
	for _, override := range overrides {
		merged = Merge(merged, override)
	}
	return merged
}

