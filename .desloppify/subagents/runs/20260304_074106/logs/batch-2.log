	nestd := ""
	if len(urlParts) >= 2 {
		nestd = strings.Join(urlParts[:2], ".")
	}
	switch {
	case nestd == "ames."+patp && remote.SvcType == string(transition.StartramServiceTypeUrbitAmes) && remote.Status == string(transition.StartramServiceStatusOk):
