  "dimension_notes": {
    "cross_module_architecture": {
      "evidence": [
        "Mutable exported package singletons are used as cross-module state buses: `config.VersionInfo`/`config.VersionServerReady` (`goseg/config/version.go:17-20`, mutated at `:120-139`) and `startram.EventBus`/`startram.Regions` (`goseg/startram/startram.go:33-36`, mutated at `:73`, `:138`).",
        "`startram` mixes API client logic, config persistence, event emission, system probing, Docker command execution, archive extraction, and crypto in one module (`goseg/startram/startram.go` imports `config`, `click`, `system`, `os/exec`, `net/http`, `archive/tar`, `crypto/*`).",
        "Handler entrypoints are tightly bound to concrete subsystem packages instead of a boundary interface (`goseg/handler/upload.go:19-26` calls `importer` directly; `goseg/startram/startram.go:122-138` mutates `config` and publishes to package event bus within retrieval flow)."
      ],
      "impact_scope": "subsystem",
      "fix_scope": "architectural_change",
      "confidence": "high"
    }
  },
  "findings": [
    {
      "dimension": "cross_module_architecture",
      "identifier": "shared_singleton_state_channels",
      "summary": "Exported mutable package globals are used as coordination channels across modules, creating hidden coupling and broad blast radius.",
      "related_files": [
        "goseg/config/version.go",
        "goseg/startram/startram.go"
      ],
      "evidence": [
        "`config` exposes mutable globals (`VersionServerReady`, `VersionInfo`) and writes them in `SyncVersionInfo` while callers read fallback values through `CheckVersion`.",
        "`startram` exposes mutable globals (`EventBus`, `Regions`) and mutates them in `SyncRegions` and `SyncRetrieve`, so behavior depends on package-level runtime state rather than explicit call contracts."
      ],
      "suggestion": "Replace exported mutable globals with injected state holders behind small interfaces (e.g., version repository and event publisher). Keep package vars unexported at minimum, and route updates through explicit methods so dependency direction is visible and testable.",
      "confidence": "high",
      "impact_scope": "subsystem",
      "fix_scope": "architectural_change",
      "root_cause_cluster": "implicit_runtime_state_as_boundary"
    },
    {
      "dimension": "cross_module_architecture",
      "identifier": "startram_god_module_boundary_collapse",
      "summary": "The `startram` package is a hub module spanning unrelated layers, collapsing boundaries between transport, persistence, system, and domain workflows.",
      "related_files": [
        "goseg/startram/startram.go",
        "goseg/config/version.go"
      ],
      "evidence": [
        "`startram.go` combines remote API orchestration (`http.Get/Post`), config mutation (`config.UpdateConf`, `config.Conf`), event broadcasting (`EventBus <- ...`), Docker shell execution (`exec.Command`), backup extraction (`tar`, `zstd`), and crypto (`aes/gcm`).",
        "The pattern mirrors config-side shared-state orchestration (`version.go` manages remote fetch + persistence + process-level readiness flags), indicating architectural responsibilities are centralized in package hubs instead of separated services."
      ],
      "suggestion": "Split `startram` into boundary-focused components: API client, registration service, backup service, and event adapter. Introduce dependency-injected interfaces so side effects (config writes, event publish, shell/system calls) are delegated to adapters rather than embedded in domain flow.",
      "confidence": "high",
      "impact_scope": "codebase",
      "fix_scope": "architectural_change",
      "root_cause_cluster": "missing_service_boundaries"
    },
    {
      "dimension": "cross_module_architecture",
      "identifier": "transport_to_subsystem_direct_binding",
      "summary": "Transport handlers and subsystem workflows call concrete side-effecting packages directly, bypassing a stable orchestration boundary.",
      "related_files": [
        "goseg/handler/upload.go",
        "goseg/startram/startram.go"
      ],
      "evidence": [
        "`UploadHandler` decodes websocket payloads and directly invokes `importer.SetUploadSession`/`importer.Reset` based on string action values (`upload.go:19-26`).",
        "`SyncRetrieve` performs retrieval plus direct config mutation and event publication (`startram.go:122-138`), coupling one call path to multiple subsystems.",
        "Both patterns force cross-module coordination through direct package calls and stringly command branching, increasing change coupling between protocol handlers and runtime state modules."
      ],
      "suggestion": "Introduce application-service interfaces between handlers and subsystems (e.g., `UploadService`, `StartramService`) and map transport actions to typed commands at the edge. Keep state mutation/event emission behind those services to preserve boundary integrity.",
      "confidence": "medium",
      "impact_scope": "subsystem",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "missing_service_boundaries"
    }
  ],
  "retrospective": {
    "root_causes": [
      "Runtime coordination is implemented with exported package globals instead of explicit state/repository interfaces.",
      "Subsystem packages are used as orchestration layers, accumulating responsibilities from multiple architectural tiers."
    ],
    "likely_symptoms": [
      "shared_singleton_state_channels",
      "transport_to_subsystem_direct_binding"
    ],
    "possible_false_positives": []
  }
}


