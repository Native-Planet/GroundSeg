      "evidence": [
        "startup orchestrator and server bootstrap paths both decouple critical startup work into goroutines and capture only partial errors from those goroutines (timeout-gated fail-fast + single-slot unexpected error retention)",
        "background startup errors are treated as optional if they arrive too late, and server listener errors are normalized to a single preserved value instead of a complete error set"
      ],
      "impact_scope": "subsystem",
