func TestRandStringReturnsEncodedData(t *testing.T) {
	got := RandString(32)
	if got == "" {
		t.Fatal("expected non-empty random string")
	}
	// base64 output should be longer than input bytes.
	if len(got) <= 32 {
		t.Fatalf("expected encoded string longer than 32, got %d", len(got))
	}
}
