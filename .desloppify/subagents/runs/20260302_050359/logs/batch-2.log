      "dimension": "abstraction_fitness",
      "identifier": "wg_default_config_split_brain",
      "summary": "Wireguard defaults are defined in multiple independent modules, creating duplicate source-of-truth for default runtime/container behavior.",
      "related_files": [
        "goseg/defaults/defaults.go",
        "goseg/config/wireguardbuilder/builder.go",
        "goseg/docker/orchestration/container/wireguard.go"
