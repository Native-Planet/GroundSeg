      "identifier": "rectify_context_loss_on_returned_errors",
      "summary": "Rectify reconciliation returns several raw errors without operation context while neighboring paths wrap context.",
      "related_files": [
        "goseg/rectify/rectify_services.go",
        "goseg/docker/orchestration/subsystem/subsystem_health.go",
