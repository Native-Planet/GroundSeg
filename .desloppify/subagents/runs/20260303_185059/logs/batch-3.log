      "identifier": "channel_backpressure_failure_modes_diverge",
      "summary": "Internal event channels use conflicting overflow/failure semantics, yielding unpredictable behavior under load.",
      "related_files": [
        "goseg/docker/orchestration/subsystem/subsystem_events.go",
        "goseg/broadcast/state.go",
        "goseg/leak/broadcast.go"
