    {
      "dimension": "cross_module_architecture",
      "identifier": "c2c_action_alias_duplication",
      "summary": "Protocol action contracts are duplicated across layers instead of owned by a single boundary.",
      "related_files": [
        "goseg/protocol/actions/actions.go",
        "goseg/system/wifi/service/c2c_service.go"
      ],
      "evidence": [
        "`ActionC2CConnect` is defined in `goseg/protocol/actions/actions.go` as the canonical protocol token.",
        "`goseg/system/wifi/service/c2c_service.go` introduces `ConnectAction` as a second alias assigned to the same token.",
        "Both identifiers represent the same semantic command, so any rename or semantic change must be mirrored manually in multiple modules."
      ],
      "suggestion": "Delete the local `ConnectAction` alias and use the protocol contract symbol directly at all call sites, or introduce a single exported canonical symbol in `actions` and remove per-layer command aliases so contract changes are made once.",
      "confidence": "high",
      "impact_scope": "module",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "c2c_action_contract_scatter"
    },
    {
      "dimension": "cross_module_architecture",
      "identifier": "c2c_dispatcher_global_init_coupling",
      "summary": "C2C action dispatch is bound at package scope, increasing coupling and reducing composability across module boundaries.",
      "related_files": [
        "goseg/system/wifi/service/c2c_service.go",
        "goseg/protocol/actions/actions.go"
      ],
      "evidence": [
        "`goseg/system/wifi/service/c2c_service.go` defines `c2cActionDispatcher` as a global variable initialized with `actions.NewActionDispatcher(...)`.",
        "All command execution paths read from this singleton dispatcher, which ties this package’s runtime behavior to import-time construction of bindings and fixed semantics."
      ],
      "suggestion": "Refactor to construct the dispatcher explicitly (for example in `NewC2CServiceForAdapter`/`ProcessC2CMessage`) and pass it in as a dependency so action wiring is explicit, testable, and replaceable by callers without editing global package state.",
