func BroadcastToClientsWithRuntime(rt broadcastRuntime) error {
	bState := GetState()
	rt.emitToLeak(bState) // vere 3.0
	if !rt.hasAuthSession() {
		return nil
	}
	authJson, err := GetStateJson(bState)
	if err != nil {
		return err
	}
	return rt.broadcastAuth(authJson)
}

