package system

import "fmt"

var c2cServiceFactory = newC2CServiceForAdapter
var connectToWifiForC2C = ConnectToWifi
var restartGroundSegForC2C = restartGroundSegService

func c2cActionExecutorForAdapter(action c2cAction, ssid, password string) error {
	service := c2cServiceFactory()
	return service.Execute(action, ssid, password)
}

func parseC2CAction(raw string) (c2cAction, error) {
	action := c2cAction(raw)
	switch action {
	case c2cActionConnect:
		return action, nil
	default:
		return action, unsupportedC2CActionError{Action: action}
