      "dimension": "abstraction_fitness",
      "identifier": "global_function_seams_as_default_DI",
      "summary": "Replace widespread mutable global function seams with explicit dependency containers to avoid brittle abstraction boundaries.",
      "related_files": [
        "main.go",
        "system/wifi.go",
        "shipworkflow/startram.go",
        "handler/system_test.go"
