    "review::.::holistic::design_coherence::shipworkflow_orchestration_monolith::449a6ebe": {
      "id": "review::.::holistic::design_coherence::shipworkflow_orchestration_monolith::449a6ebe",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Operational responsibilities in ship orchestration are concentrated in one file, creating a low-cohesion orchestration nucleus.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "shipworkflow/urbit_operations.go",
          "shipworkflow/startram.go"
        ],
        "evidence": [
          "`shipworkflow/urbit_operations.go` mixes container/service installation, rebuild/install/uninstall flows, backups, lifecycle transitions, network/power toggles, and pier/container transition orchestration in a single large file.",
          "Adjacent workflow file `shipworkflow/startram.go` adds related orchestration entrypoints, indicating coordination logic is spread across files by feature edges rather than by stable bounded responsibilities."
        ],
        "suggestion": "Split the file into explicit use-case services (e.g., install/uninstall, lifecycle, networking/power, pier registration) behind narrow interfaces and compose them through a small orchestration coordinator; move helper logic into reusable modules with focused tests per concern.",
        "reasoning": ""
      },
      "status": "open",
