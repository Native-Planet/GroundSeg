    "review::.::holistic::cross_module_architecture::structural_boundary_error_contracts::5e9b8633": {
      "id": "review::.::holistic::cross_module_architecture::structural_boundary_error_contracts::5e9b8633",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Boundary helpers mix typed errors, logging-only behavior, and false-success returns, weakening fault propagation across modules.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "config/config.go",
          "docker/docker.go",
          "accesspoint/router.go",
          "handler/support.go"
        ],
        "evidence": [
          "Some boundary functions return rich errors while adjacent helpers only log and continue or return hardcoded `true`.",
          "This produces inconsistent recovery behavior for callers that coordinate startup and external side effects."
        ],
        "suggestion": "Define a consistent cross-module error contract for boundary operations (explicit status + wrapped cause), and align callsites to act on those outcomes before continuing.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T16:26:17+00:00",
