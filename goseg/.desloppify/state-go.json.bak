    "review::.::holistic::design_coherence::docker_event_loop_multi_responsibility::526e4a83": {
      "id": "review::.::holistic::design_coherence::docker_event_loop_multi_responsibility::526e4a83",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Docker event loop combines event decoding, policy decisions, state mutation, and transition publishing in one place.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "routines/docker.go",
          "docker/docker.go",
          "broadcast/broadcast.go",
          "shipworkflow/urbit_operations.go"
        ],
        "evidence": [
          "`dockerSubscriptionHandler` in `routines/docker.go` directly couples event intake, container state bookkeeping, restart policy, state-specific side effects, and broadcast signaling for each action.",
          "The same file performs ship restart logic (`go routine ... rt.startContainer`) and wireguard/leech state mutation from inside the event switch, so policy and transport handling are tightly entangled.",
          "This broad responsibility repeats for each event type, increasing branching complexity and making new event policies hard to reason about safely."
        ],
        "suggestion": "Move event translation into small handlers (e.g., per action handlers with explicit invariants), and make Docker event routing invoke injected policy modules so runtime/event mechanics are separated from action semantics.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
