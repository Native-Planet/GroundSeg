    "review::.::holistic::error_consistency::err_dg_get_container_running_status_nil_client::20d04e36": {
      "id": "review::.::holistic::error_consistency::err_dg_get_container_running_status_nil_client::20d04e36",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Docker status helper can dereference a nil client on client construction failure.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "docker/docker.go",
          "docker/minio.go",
          "docker/netdata.go"
        ],
        "evidence": [
          "`GetContainerRunningStatus` checks `if err != nil {}` and still calls `cli.Close()` and `cli.ContainerList(...)`, so `dockerclient.New()` failures are not handled.",
          "This helper is used in container config builders and startup loops, so a transient client construction failure can crash dependent flows."
        ],
        "suggestion": "Return immediately with wrapped error when `dockerclient.New()` fails, and keep the function\u2019s error contract explicit for all callers.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T16:26:17+00:00",
      "last_seen": "2026-03-01T16:26:17+00:00",
      "resolved_at": "2026-03-01T20:17:36+00:00",
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::design_coherence::design_accesspoint_router_ignores_shell_errors::d98907f8": {
      "id": "review::.::holistic::design_coherence::design_accesspoint_router_ignores_shell_errors::d98907f8",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Access point start/stop always report success while discarding shell command failures.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "accesspoint/router.go",
          "accesspoint/accesspoint.go",
          "accesspoint/parameters.go"
        ],
        "evidence": [
          "`startRouter` and `stopRouter` call `executeRouterShellFn(...)` repeatedly with `res, err` but never branch on `err`.",
          "`Start()` in `accesspoint/accesspoint.go` does not inspect those outcomes and returns nil regardless."
        ],
        "suggestion": "Track first command failure through `startRouter`/`stopRouter` and return the concrete error so caller can decide whether to abort, retry, or roll back.",
        "reasoning": ""
      },
      "status": "fixed",
      "note": "startRouter/stopRouter now return wrapped command errors instead of bool; Start/Stop propagate those failures, and router tests were updated to assert success via nil error and check contextual error output.",
      "first_seen": "2026-03-01T16:26:17+00:00",
      "last_seen": "2026-03-01T16:26:17+00:00",
      "resolved_at": "2026-03-01T17:58:59+00:00",
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
        "kind": "manual",
        "text": "I have actually changed startRouter and stopRouter to return concrete errors and wired Accesspoint Start/Stop to propagate those errors, rather than always returning success; I am not gaming the score by resolving without fixing.",
        "attested_at": "2026-03-01T17:58:59+00:00",
        "scan_verified": false
      }
    },
    "review::.::holistic::cross_module_architecture::arch_cfg_init_fatal_continue::9620e3bf": {
      "id": "review::.::holistic::cross_module_architecture::arch_cfg_init_fatal_continue::9620e3bf",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Config initialization silently tolerates bootstrap failures and allows process startup with partially initialized global state.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "config/config.go",
          "main.go",
          "broadcast/broadcast.go"
        ],
        "evidence": [
          "`initializeConfig()` logs failures in `openOrCreateConfigFile` and returns without escalating an error.",
          "`init()` calls `initializeConfig()` unconditionally, while startup in `main.go` proceeds even when config substrate is potentially invalid."
        ],
        "suggestion": "Split bootstrap into an explicit `Initialize() error` entry point, fail fast or enter a clearly defined degraded mode on unrecoverable failures, and avoid continuing anonymous side-effectful startup from `init()`.",
        "reasoning": ""
      },
      "status": "fixed",
      "note": null,
      "first_seen": "2026-03-01T16:26:17+00:00",
      "last_seen": "2026-03-01T16:26:17+00:00",
      "resolved_at": "2026-03-01T17:54:21+00:00",
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
        "kind": "manual",
        "text": "I have actually added an explicit config.Initialize() that returns initialization errors, removed silent init-time config bootstrap, added main startup fail-fast behavior, and added a broadcast initialization guard when config is not ready, and I am not gaming the score by resolving without fixing.",
        "attested_at": "2026-03-01T17:54:21+00:00",
        "scan_verified": false
      }
    },
    "review::.::holistic::error_consistency::err_support_submit_bugreport_bad_error_path::e4ef9683": {
      "id": "review::.::holistic::error_consistency::err_support_submit_bugreport_bad_error_path::e4ef9683",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Bug report sender drops multipart/http operation errors and returns an unhelpful non-200 error value.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "handler/support.go",
          "handler/system.go"
        ],
        "evidence": [
          "`sendBugReport` ignores errors from `writer.WriteField`, `writer.CreateFormFile`, and `writer.Close()`, so malformed requests can pass to `client.Do` and fail later with poor diagnostics.",
          "On non-200 responses, it returns `fmt.Errorf(\"%s: %s\", resp.Status, resp.Body)` which stringifies an `io.ReadCloser` rather than the server body."
        ],
        "suggestion": "Check and propagate multipart writer errors, close the writer before request execution, and read/trim response body before wrapping transport errors.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-01T16:26:17+00:00",
      "last_seen": "2026-03-01T16:26:17+00:00",
      "resolved_at": "2026-03-01T20:17:36+00:00",
      "reopen_count": 0,
      "lang": "go",
