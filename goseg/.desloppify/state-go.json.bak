    },
    "review::.::holistic::error_consistency::EC-004::0e3cffc6": {
      "id": "review::.::holistic::error_consistency::EC-004::0e3cffc6",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Volume writer drops tar writer close errors when setup fails mid-archive creation.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "docker/orchestration/volume_writer.go",
          "docker/orchestration/runtime_seams_test.go"
        ],
        "evidence": [
          "In error handling branches inside archive creation, `tw.Close()` is called with `_ = tw.Close()`, and errors are dropped.",
          "This occurs in paths already returning from copy/write failures, so close/flush/flush-to-archive errors can be lost."
        ],
        "suggestion": "Capture `tw.Close()` errors in each return path and prefer combining/surfacing them with the original error so archive integrity or finalization failure is not silently ignored.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-01T20:17:36+00:00",
      "last_seen": "2026-03-01T20:17:36+00:00",
      "resolved_at": null,
