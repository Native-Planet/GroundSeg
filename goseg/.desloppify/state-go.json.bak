    "review::.::holistic::abstraction_fitness::duplicated_pass_through_runtime_seams::b64c2bb0": {
      "id": "review::.::holistic::abstraction_fitness::duplicated_pass_through_runtime_seams::b64c2bb0",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Multiple packages maintain parallel, thin runtime-seam abstractions that add indirection without creating real policy boundaries.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "routines/docker.go",
          "docker/orchestration/runtime_seams.go",
          "shipworkflow/startram.go"
        ],
        "evidence": [
          "Each file defines its own runtime interface type and default struct implementation that primarily forwards calls to underlying package functions.",
          "There is substantial overlap in responsibilities across these seam bundles (container/image/config/wireguard/urbit-like concerns) with little unique behavior.",
          "Callers gain extra hops before reaching concrete logic, but the seams are not used to encapsulate different strategies or boundaries beyond test substitution."
        ],
        "suggestion": "Consolidate into a single shared seam model per subsystem (e.g., one runtime abstraction for orchestration/deploy workflows), remove redundant duplicate interfaces, and migrate callsites to depend on one explicit abstraction with meaningful behavior-oriented methods only.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-01T20:17:36+00:00",
      "last_seen": "2026-03-01T20:17:36+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::abstraction_fitness::compat_wrapper_chain_without_policy::a1365514": {
      "id": "review::.::holistic::abstraction_fitness::compat_wrapper_chain_without_policy::a1365514",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Compatibility and `WithRuntime` wrapper layering in broadcast/wireguard paths preserves old APIs but increases churn for equivalent call paths.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "broadcast/broadcast.go",
          "docker/orchestration/wireguard.go",
          "docker/orchestration/wireguard_test.go",
          "routines/docker.go"
        ],
        "evidence": [
          "`broadcast/broadcast.go` exposes `ApplyBroadcastUpdate` as a pass-through compatibility shim over `ApplyBroadcastTransition`.",
          "Wireguard orchestration code adds `*WithRuntime` forms that primarily thread runtime fields and delegate to existing apply logic, duplicating invocation shape.",
          "Tests and helpers reference both styles, increasing maintenance surface and cognitive load with no clear behavior split."
        ],
        "suggestion": "Collapse wrappers by choosing one canonical API surface (e.g., keep the newer apply path), deprecate and remove compatibility entry points in a single sweep, and update callers/tests together to avoid dual invocation paths.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-01T20:17:36+00:00",
      "last_seen": "2026-03-01T20:17:36+00:00",
      "resolved_at": null,
      "reopen_count": 0,
