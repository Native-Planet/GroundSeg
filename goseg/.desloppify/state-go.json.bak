    },
    "review::.::holistic::cross_module_architecture::action_contract_not_used_as_source_of_truth::03c699ba": {
      "id": "review::.::holistic::cross_module_architecture::action_contract_not_used_as_source_of_truth::03c699ba",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Upload adapter contract tests bypass the documented protocol contract and can pass while action sources diverge.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "README.md",
          "protocol/actions/actions.go",
          "uploadsvc/adapters/upload_payload_test.go"
        ],
        "evidence": [
          "`README.md` explicitly states `protocol/actions` is the single source of truth for websocket action tokens.",
          "The adapter test imports `uploadsvc` constants (`uploadsvc.ActionOpenEndpoint`, `uploadsvc.ActionReset`) instead of `protocol/actions` action constants.",
          "Unsupported-action behavior in the test is asserted via `uploadsvc.UnsupportedActionError` only, not protocol-level unsupported-action semantics."
        ],
        "suggestion": "Refactor the upload payload tests (and adapter command parser contracts) to depend on `protocol/actions` for all action literals and parser checks, then assert adapter-facing command results are a stable projection of protocol actions. Add a compile-time or test-time guard that fails when protocol action constants change without corresponding adapter updates.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-01T20:17:36+00:00",
      "last_seen": "2026-03-01T20:17:36+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "lang": "go",
