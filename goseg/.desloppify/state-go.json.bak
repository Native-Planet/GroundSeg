    "review::.::holistic::abstraction_fitness::runtime_state_isolated_by_name_but_not_dependency_graph::f8e15578": {
      "id": "review::.::holistic::abstraction_fitness::runtime_state_isolated_by_name_but_not_dependency_graph::f8e15578",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Injected seam structs still depend heavily on concrete package globals, so seams do not isolate callers from external dependency changes.",
      "detail": {
        "holistic": true,
        "dimension": "abstraction_fitness",
        "related_files": [
          "importer/importer.go",
          "config/config.go",
          "auth/auth.go",
          "defaults/defaults.go",
          "routines/docker.go"
        ],
        "evidence": [
          "Runtime seams are present, but most methods resolve behavior through package-level calls instead of explicit interfaces for externally swappable providers.",
          "This reduces the practical benefit of dependency inversion: tests can replace some adapters, yet production code remains coupled to concrete package-level behavior.",
          "The resulting abstraction graph is leaky: injection appears available in type declarations, but runtime behavior is still owned by direct module-level dependencies."
        ],
        "suggestion": "Introduce stable repository-facing interfaces for config/auth/docker/network/wireguard dependencies and inject those through a single constructor root, keeping defaults as concrete implementations only at process boundary.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-01T20:17:36+00:00",
      "last_seen": "2026-03-01T20:17:36+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "lang": "go",
      "suppressed": false,
