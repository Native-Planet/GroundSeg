    "review::.::holistic::design_coherence::support_handler_duplication::3e03ca50": {
      "id": "review::.::holistic::design_coherence::support_handler_duplication::3e03ca50",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Bug-report support handling is duplicated across two packages instead of sharing a single coherent abstraction.",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "system/system.go",
          "handler/system/support.go"
        ],
        "evidence": [
          "Both files define/consume overlapping support flow components: handler entrypoints (`SupportHandler`/`SupportHandlerWithRuntime`), JSON sanitization (`sanitizeJSON`), zip creation (`zipDir`), and report transport (`sendBugReportWithEndpoint`, `dumpBugReport`, `lastTwoLogs`).",
          "The same constants and transport behavior (`s3`, telemetry-style bug report endpoint interaction pattern) appear mirrored rather than delegated to one canonical implementation."
        ],
        "suggestion": "Extract a shared support/bug-report package or service interface with a single implementation and inject it from both packages; keep package-specific handlers thin wrappers. This should consolidate validation, sanitization, archive creation, and endpoint calls, and make future format changes one-location-only.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
