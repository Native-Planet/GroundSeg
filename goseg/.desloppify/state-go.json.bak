    "review::.::holistic::cross_module_architecture::mutable_global_c2c_dependency_seams::52cce901": {
      "id": "review::.::holistic::cross_module_architecture::mutable_global_c2c_dependency_seams::52cce901",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "C2C execution flow depends on mutable package-level function indirection rather than explicit dependency wiring.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "system/wifi_c2c_service.go",
