    "review::.::holistic::error_consistency::EC-005::d3b941a5": {
      "id": "review::.::holistic::error_consistency::EC-005::d3b941a5",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Mount-table octal-to-ASCII parsing ignores conversion errors and continues with potentially invalid mount points.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "system/system.go",
          "system/disk.go"
        ],
        "evidence": [
          "`GetDisk` assigns `mountPoint, _ := octalToAscii(fields[1])`, explicitly discarding the parser error.",
          "The function continues to call `syscall.Statfs` using a possibly malformed mount point instead of failing early or handling the parse failure."
        ],
        "suggestion": "Handle the `octalToAscii` error explicitly: skip invalid entries with a warning and avoid stat on malformed paths, or fail the scan with explicit diagnostics.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
