        "related_files": [
          "importer/importer.go",
          "shipworkflow/operations_runtime.go",
          "startuporchestrator/startup_orchestrator.go",
          "docker/orchestration/runtime_ops.go",
          "rectify/rectify.go"
        ],
        "evidence": [
          "`docker/orchestration/runtime_ops.go` defines broad cross-domain runtime structs that are reused by importer/workflow/rectify, so each consumer inherits many callbacks beyond its core responsibility.",
          "`importer/importer.go` and `shipworkflow/operations_runtime.go` both validate long callback lists manually, showing abstraction cost has shifted to defensive wiring rather than simpler domain contracts.",
          "`rectify/rectify.go` and `startuporchestrator/startup_orchestrator.go` layer additional runtime composition/merge logic on top of these bundles, increasing maintenance surface for every seam rename or new callback."
        ],
        "suggestion": "Refactor runtime seams into smaller capability interfaces per use-case (for example, `UrbitConfigMutator`, `ContainerLifecycle`, `TransitionPublisher`) and inject only those into each subsystem. Replace manual nil-check lists with grouped interface assertions so adding/removing callbacks does not require synchronized edits across multiple runtime builders and validators.",
        "reasoning": ""
      },
      "status": "open",
      "primary_command": "desloppify issues"
    }
