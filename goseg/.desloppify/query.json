  "finding": {
    "id": "review::.::holistic::abstraction_fitness::inconsistent_wrapper_contracts::ced3747e",
    "summary": "Wrapper abstractions expose inconsistent contracts (silent no-op vs hard error), making interfaces dishonest and harder to reason about.",
    "detail": {
      "holistic": true,
      "dimension": "abstraction_fitness",
      "related_files": [
        "importer/importer.go",
        "startuporchestrator/startup_orchestrator.go",
        "main.go"
      ],
      "evidence": [
        "importer/importer.go has wrappers that sometimes fail hard on nil dependencies (startContainer/deleteVolume) but other wrappers silently do nothing (updateContainer, waitForBootCode/waitForRemoteReady when lifecycleOps is nil).",
        "startuporchestrator/startup_orchestrator.go has storage callbacks that silently no-op when unset (configureSwap/setupTmpDir return nil), while other callbacks are treated as required via validate().",
        "main.go bootstrapRuntime.startServer and runC2cCheck return nil if callback is missing, but startup options in orchestrator treat server startup as required behavior."
      ],
      "suggestion": "Define one contract style per runtime seam: either required dependencies validated at construction (no nil branches in hot paths) or explicit optional dependencies modeled as Optional* fields with documented no-op behavior. Apply consistently across wrappers.",
      "reasoning": ""
    }
  },
